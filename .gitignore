# ============================================
# Bitchat Platform - Git Ignore Rules
# ============================================

# User uploaded content (DO NOT commit user data)
upload/
themes/upload/photos/
themes/upload/videos/
themes/upload/sounds/
themes/upload/files/
vendorthemes/upload/videos/
vendorthemes/upload/photos/
vendorthemes/upload/sounds/

# Configuration files (contain sensitive data)
config.php
.env
*.env
nodejs/config.json

# Cache and temporary files
cache/
/changes
*_updated.php

# Database dumps and backups
*.sql
!sql/*.sql
!database/*.sql
*.sql.gz
*.bak
backup/
backups/
script_backups/

# Log files
*.log
logs/

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
__MACOSX/

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Node.js
nodejs/node_modules/
node_modules/
npm-debug.log*

# Generated language file
/nodejs/models/wo_langs.js

# ZIP archives (already extracted)
*.zip

# Temporary and test files
*.tmp
*.temp
test_*
temp/

# Localhost server PID and log files
.php-server.pid
.nodejs-server.pid
php-server.log
nodejs-server.log

# Installer files (remove after installation)
instoll/
install.zip
install/

# Security - never commit these
*.pem
*.key
*.crt
*.p12
secrets/
credentials/
.env.local
.env.*.local

# Package lock files (optional - uncomment if needed)
# package-lock.json
# yarn.lock

# Build and distribution
dist/
build/
*.out

# Error logs
error_log
php_errors.log

# Source maps (not needed in production)
*.js.map

# FFmpeg docs and models (binary is needed, docs are not)
ffmpeg/manpages/
ffmpeg/model/

# Test/sample videos
admin-panel/videos/test*.mp4

# Composer binary (install globally instead)
composer.phar
