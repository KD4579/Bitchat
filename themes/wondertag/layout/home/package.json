{
    "name": "bitchat-desktop",
    "version": "1.0.0",
    "description": "BitChat Desktop App",
    "main": "main.js",
    "author": "Sunil",
    "scripts": {
      "start": "electron .",
      "build": "electron-builder"
    },
    "dependencies": {},
    "devDependencies": {
      "electron": "^29.3.0",
      "electron-builder": "^24.13.2"
    },
    "build": {
      "appId": "com.bitchat.desktop",
      "productName": "BitChat",
      "directories": {
        "output": "dist"
      },
      "files": [
        "**/*"
      ],
      "win": {
        "target": "nsis",
        "icon": "icon.png"
      },
      "mac": {
        "target": "dmg",
        "icon": "icon.png"
      },
      "linux": {
        "target": "AppImage",
        "icon": "icon.png"
      }
    }
  }
  