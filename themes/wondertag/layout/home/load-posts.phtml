<?php
// Bitchat Algorithm v1: use ranked feed when enabled, else chronological
if (!empty($wo['config']['feed_algorithm_enabled']) && $wo['config']['feed_algorithm_enabled'] == '1' && $wo['loggedin'] && function_exists('Wo_GetRankedPosts')) {
    $stories = Wo_GetRankedPosts(array('limit' => 10, 'page' => 1));
} else {
    $stories = Wo_GetPosts(array('limit' => 10, 'publisher_id' => 0, 'placement' => 'multi_image_post', 'anonymous' => true));
}
?>
<div id="posts">
	<?php
		if ($wo['config']['pro'] == 1) {
		$promoted = $wo['story'] = Wo_GetPromotedPost();
		if (count($promoted) > 0) {
		$wo['story']['post_is_promoted'] = 1;
	?>
		<div class="promoted-post">
			<?php echo Wo_LoadPage('story/content'); ?>
		</div>
	<?php } } ?>
	<?php
		if (count($stories) <= 0) {
			echo Wo_LoadPage('story/no-stories');
			echo '<div class="home_no_post_people"></div>';
		} else {
			echo '<div class="home_post_people">';
			foreach ($stories as $wo['story']) {
				echo Wo_LoadPage('story/content');
			}
			echo '</div>';
		}
	?>
</div>
<?php if (count($stories) > 0) { ?>
	<div class="load-more pointer" id="load-more-posts" onclick="Wo_GetMorePosts();">
		<span class="btn btn-default text-center pointer"><span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"></path></svg></span> <?php echo $wo['lang']['load_more_posts'];?></span>
	</div>
<?php } ?>
<div id="load-more-filter">
	<span class="filter-by-more hidden" data-filter-by="all"></span>
</div>
<script>
<?php
// BC-SUG: Friend suggestion schedule — runs AFTER posts HTML is in the DOM
$users = Wo_UserSug(8);
if (count($users) != 0) {
  $sug_html = '<div class="wow_content tag_sidebar_widget tag_post_people_know"><div class="valign tag_sidebar_widget_title"><b>' . $wo['lang']['people_you_may_know'] . '</b><a onclick="Wo_ReloadSideBarUsers();" class="refresh">' . $wo['lang']['home_refresh'] . '</a></div><div class="tag_scroll sidebar-users-may-know-container">';
  foreach ($users as $wo['UsersList']) {
    $wo['UsersList']['user_name'] = mb_substr($wo['UsersList']['name'], 0, 10, "utf-8");
    $sug_html .= Wo_LoadPage('sidebar/sidebar-user-list');
  }
  $sug_html .= '</div><div class="clear"></div></div>';
  $sug_js = addslashes(preg_replace('/\s+/', ' ', trim($sug_html)));
?>
// After post 3 (nth-child 2 + promoted = 3 visible)
$("<?php if (count($stories) <= 0) { ?>.home_no_post_people<?php } else { ?>.home_post_people .post-container:nth-child(2)<?php } ?>").append('<?php echo $sug_js; ?>');
<?php if (count($stories) > 7) { ?>
// After post 8 (nth-child 7 + promoted = 8 visible)
$(".home_post_people .post-container:nth-child(7)").append('<?php echo $sug_js; ?>');
<?php } ?>
<?php } ?>
</script>
