					<p style="color:#94a3b8;font-size:13px;text-align:center;">Loading...</p>
				</div>
			</div>

			<script>
			function getDepositAddress() {
				var btn = document.querySelector('#deposit-address-loading button');
				btn.disabled = true;
				btn.textContent = 'Generating...';

				$.post('<?php echo $wo['config']['site_url']; ?>/requests.php?f=deposit_address', {
					action: 'get_address',
					hash: '<?php echo Wo_CreateMainSession(); ?>'
				}, function(resp) {
					if (resp.status === 200 && resp.address) {
						document.getElementById('deposit-address-text').textContent = resp.address;
						document.getElementById('deposit-bscscan-link').href = 'https://bscscan.com/address/' + resp.address;
						document.getElementById('deposit-address-display').style.display = 'block';
						document.getElementById('deposit-address-loading').style.display = 'none';
						generateQR(resp.address);
					} else {
						btn.disabled = false;
						btn.textContent = 'Generate Deposit Address';
						Wo_ShowNotification(resp.message || 'Error generating address', 'error');
					}
				}, 'json').fail(function() {
					btn.disabled = false;
					btn.textContent = 'Generate Deposit Address';
					Wo_ShowNotification('Network error', 'error');
				});
			}

			function generateQR(address) {
				var canvas = document.getElementById('deposit-qr-canvas');
				if (typeof QRCode !== 'undefined') {
					QRCode.toCanvas(canvas, address, { width: 184, margin: 0 }, function(err) {
						if (err) console.error('QR error:', err);
					});
				} else {
					// Load QRCode library dynamically
					var script = document.createElement('script');
					script.src = 'https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js';
					script.onload = function() {
						QRCode.toCanvas(canvas, address, { width: 184, margin: 0 }, function(err) {
							if (err) console.error('QR error:', err);
						});
					};
					document.head.appendChild(script);
				}
			}

			function copyDepositAddress() {
				var addr = document.getElementById('deposit-address-text').textContent;
				if (navigator.clipboard) {
					navigator.clipboard.writeText(addr).then(function() {
						Wo_ShowNotification('Address copied to clipboard', 'success');
					});
				} else {
					var temp = document.createElement('input');
					temp.value = addr;
					document.body.appendChild(temp);
					temp.select();
					document.execCommand('copy');
					document.body.removeChild(temp);
					Wo_ShowNotification('Address copied to clipboard', 'success');
				}
			}

			function loadDepositBalances() {
				$.post('<?php echo $wo['config']['site_url']; ?>/requests.php?f=deposit_address', {
					action: 'balances',
					hash: '<?php echo Wo_CreateMainSession(); ?>'
				}, function(resp) {
					if (resp.status === 200 && resp.balances) {
						document.getElementById('bal-trdc').textContent = resp.balances.trdc || '0';
						document.getElementById('bal-usdt').textContent = resp.balances.usdt || '0';
						document.getElementById('bal-bnb').textContent = resp.balances.bnb || '0';
					}
				}, 'json');
			}

			function loadDepositHistory(page) {
				page = page || 1;
				$.post('<?php echo $wo['config']['site_url']; ?>/requests.php?f=deposit_address', {
					action: 'history',
					page: page,
					hash: '<?php echo Wo_CreateMainSession(); ?>'
				}, function(resp) {
					if (resp.status === 200) {
						if (resp.deposits.length === 0) {
							$('#deposit-history-table').html('<p style="color:#94a3b8;font-size:13px;text-align:center;">No deposits yet</p>');
							return;
						}
						var html = '<table style="width:100%;font-size:12px;border-collapse:collapse;">';
						html += '<tr style="background:#f1f5f9;"><th style="padding:8px;text-align:left;">Token</th><th style="padding:8px;text-align:right;">Amount</th><th style="padding:8px;text-align:center;">Status</th><th style="padding:8px;text-align:center;">Confirmations</th><th style="padding:8px;text-align:center;">TX</th><th style="padding:8px;text-align:right;">Date</th></tr>';
						resp.deposits.forEach(function(d) {
							var statusColors = {
								'detected': '#f59e0b',
								'confirmed': '#3b82f6',
								'credited': '#10b981',
								'swept': '#10b981',
								'failed': '#ef4444'
							};
							var statusLabels = {
								'detected': 'Pending',
								'confirmed': 'Confirmed',
								'credited': 'Credited',
								'swept': 'Credited',
								'failed': 'Failed'
							};
							var color = statusColors[d.status] || '#94a3b8';
							var label = statusLabels[d.status] || d.status;
							var txLink = d.tx_hash ? '<a href="https://bscscan.com/tx/' + d.tx_hash + '" target="_blank" style="color:#3b82f6;font-size:11px;">' + d.tx_hash.substring(0, 10) + '...</a>' : '-';
							var date = new Date(d.created_at * 1000).toLocaleDateString();

							html += '<tr style="border-bottom:1px solid #f1f5f9;">';
							html += '<td style="padding:8px;">' + d.token + '</td>';
							html += '<td style="padding:8px;text-align:right;font-weight:600;">' + d.amount + '</td>';
							html += '<td style="padding:8px;text-align:center;"><span style="color:' + color + ';font-weight:600;font-size:11px;">' + label + '</span></td>';
							html += '<td style="padding:8px;text-align:center;">' + d.confirmations + '</td>';
							html += '<td style="padding:8px;text-align:center;">' + txLink + '</td>';
							html += '<td style="padding:8px;text-align:right;color:#64748b;">' + date + '</td>';
							html += '</tr>';
						});
						html += '</table>';

						if (resp.pages > 1) {
							html += '<div style="text-align:center;margin-top:10px;">';
							for (var p = 1; p <= resp.pages; p++) {
								html += '<button onclick="loadDepositHistory(' + p + ')" style="margin:0 2px;padding:4px 10px;border:1px solid ' + (p === resp.page ? '#3b82f6' : '#e2e8f0') + ';background:' + (p === resp.page ? '#3b82f6' : '#fff') + ';color:' + (p === resp.page ? '#fff' : '#334155') + ';border-radius:4px;cursor:pointer;font-size:11px;">' + p + '</button>';
							}
							html += '</div>';
						}

						$('#deposit-history-table').html(html);
					}
				}, 'json');
			}

			// Check if user already has a deposit address
			$(document).ready(function() {
				loadDepositBalances();
				loadDepositHistory();

				// Auto-check for existing address
				$.post('<?php echo $wo['config']['site_url']; ?>/requests.php?f=deposit_address', {
					action: 'get_address',
					hash: '<?php echo Wo_CreateMainSession(); ?>'
				}, function(resp) {
					if (resp.status === 200 && resp.address) {
						document.getElementById('deposit-address-text').textContent = resp.address;
						document.getElementById('deposit-bscscan-link').href = 'https://bscscan.com/address/' + resp.address;
						document.getElementById('deposit-address-display').style.display = 'block';
						document.getElementById('deposit-address-loading').style.display = 'none';
						generateQR(resp.address);
					}
				}, 'json');
			});
			</script>
		</div>
		<?php } ?>

