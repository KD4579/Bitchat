<script>
function Wo_RefreshWalletBalance() {
    var btn  = document.getElementById('wallet-refresh-btn');
    var icon = document.getElementById('wallet-refresh-icon');
    if (btn)  btn.disabled = true;
    if (icon) icon.classList.add('spinning');
    $.getJSON(Wo_Ajax_Requests_File() + '?f=wallet&s=get-balance', function(data) {
        if (data && data.status === 200) {
            $('#wallet-balance-amount').text(data.balance);
        }
    }).always(function() {
        if (btn)  btn.disabled = false;
        if (icon) icon.classList.remove('spinning');
    });
}
</script>
