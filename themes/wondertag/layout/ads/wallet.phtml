				<!-- Withdrawal History -->
				<div id="withdrawal-history-section">
					<p class="bold" style="margin-bottom:12px;">Claim History</p>
					<div id="withdrawal-history-table" style="font-size:13px;">
						<p style="color:#94a3b8; text-align:center;">Loading...</p>
					</div>
				</div>

				<script>
				// Fee preview
				document.getElementById('withdrawal-amount').addEventListener('input', function() {
					var amount = parseFloat(this.value) || 0;
					var feePercent = <?php echo $feePercent; ?>;
					var fee = (amount * feePercent / 100).toFixed(4);
					var net = (amount - fee).toFixed(4);
					var el = document.getElementById('withdrawal-fee-preview');
					if (amount > 0) {
						el.innerHTML = 'Fee: ' + fee + ' TRDC &bull; You receive: <strong style="color:#10b981;">' + net + ' TRDC</strong>';
					} else {
						el.innerHTML = '';
					}
				});

				// Submit withdrawal
				function submitTRDCWithdrawal() {
					var amount = parseFloat(document.getElementById('withdrawal-amount').value) || 0;
					var alertEl = document.getElementById('withdrawal-alert');
					var btn = document.getElementById('withdrawal-submit-btn');

					if (amount <= 0) {
						alertEl.style.display = 'block';
						alertEl.innerHTML = '<div class="alert alert-danger" style="margin:0;font-size:13px;">Please enter a valid amount</div>';
						return;
					}

					if (!confirm('Claim ' + amount.toFixed(4) + ' TRDC to your BSC wallet?\n\nYour claim will be reviewed by admin before processing.')) {
						return;
					}

					btn.disabled = true;
					btn.textContent = 'Submitting...';
					alertEl.style.display = 'none';

					$.post(Wo_Ajax_Requests_File() + '?f=trdc_withdrawal', {
						action: 'request',
						amount: amount,
						hash: $('input[name=hash]').val()
					}, function(data) {
						btn.disabled = false;
						btn.textContent = 'Claim';

						if (data.status == 200) {
							alertEl.style.display = 'block';
							alertEl.innerHTML = '<div class="alert alert-success" style="margin:0;font-size:13px;">' + data.message + '</div>';
							document.getElementById('withdrawal-amount').value = '';
							document.getElementById('withdrawal-fee-preview').innerHTML = '';
							document.getElementById('withdrawal-balance').textContent = parseFloat(data.new_balance).toFixed(4) + ' TRDC';
							// Update main wallet balance too
							var mainBal = document.getElementById('wallet-balance-amount');
							if (mainBal) mainBal.textContent = parseFloat(data.new_balance).toFixed(2);
							loadWithdrawalHistory();
						} else {
							alertEl.style.display = 'block';
							alertEl.innerHTML = '<div class="alert alert-danger" style="margin:0;font-size:13px;">' + (data.message || 'Error') + '</div>';
						}
					}, 'json').fail(function() {
						btn.disabled = false;
						btn.textContent = 'Claim';
						alertEl.style.display = 'block';
						alertEl.innerHTML = '<div class="alert alert-danger" style="margin:0;font-size:13px;">Network error. Please try again.</div>';
					});
				}

				// Cancel withdrawal
				function cancelWithdrawal(id) {
					if (!confirm('Cancel this withdrawal? The full amount will be refunded to your balance.')) return;

					$.post(Wo_Ajax_Requests_File() + '?f=trdc_withdrawal', {
						action: 'cancel',
						withdrawal_id: id,
						hash: $('input[name=hash]').val()
					}, function(data) {
						if (data.status == 200) {
							loadWithdrawalHistory();
							// Refresh balance
							var newBal = parseFloat(document.getElementById('withdrawal-balance').textContent) + data.refunded;
							document.getElementById('withdrawal-balance').textContent = newBal.toFixed(4) + ' TRDC';
							var mainBal = document.getElementById('wallet-balance-amount');
							if (mainBal) mainBal.textContent = newBal.toFixed(2);
						} else {
							alert(data.message || 'Error');
						}
					}, 'json');
				}

				// Load history
				function loadWithdrawalHistory() {
					$.post(Wo_Ajax_Requests_File() + '?f=trdc_withdrawal', {
						action: 'history',
						hash: $('input[name=hash]').val()
					}, function(data) {
						var container = document.getElementById('withdrawal-history-table');
						if (data.status != 200 || !data.withdrawals || data.withdrawals.length === 0) {
							container.innerHTML = '<p style="color:#94a3b8; text-align:center;">No withdrawals yet</p>';
							return;
						}

						var statusColors = {
							pending: '#f59e0b', approved: '#8b5cf6', processing: '#3b82f6',
							completed: '#10b981', failed: '#ef4444', cancelled: '#6b7280'
						};
						var statusLabels = {
							pending: 'Awaiting Approval', approved: 'Approved', processing: 'Sending',
							completed: 'Completed', failed: 'Failed', cancelled: 'Cancelled'
						};

						var html = '<table style="width:100%; border-collapse:collapse;">';
						html += '<thead><tr style="border-bottom:2px solid #e2e8f0;">';
						html += '<th style="text-align:left;padding:8px 6px;color:#64748b;font-size:12px;">Amount</th>';
						html += '<th style="text-align:left;padding:8px 6px;color:#64748b;font-size:12px;">Fee</th>';
						html += '<th style="text-align:left;padding:8px 6px;color:#64748b;font-size:12px;">Net</th>';
						html += '<th style="text-align:left;padding:8px 6px;color:#64748b;font-size:12px;">Status</th>';
						html += '<th style="text-align:left;padding:8px 6px;color:#64748b;font-size:12px;">TX</th>';
						html += '<th style="text-align:left;padding:8px 6px;color:#64748b;font-size:12px;">Date</th>';
						html += '<th style="padding:8px 6px;"></th>';
						html += '</tr></thead><tbody>';

						data.withdrawals.forEach(function(w) {
							var statusColor = statusColors[w.status] || '#6b7280';
							var txLink = w.tx_hash ? '<a href="https://bscscan.com/tx/' + w.tx_hash + '" target="_blank" style="color:#60a5fa;font-size:11px;text-decoration:none;">' + w.tx_hash.substring(0, 10) + '...</a>' : '-';
							var cancelBtn = w.status === 'pending' ? '<button onclick="cancelWithdrawal(' + w.id + ')" style="font-size:11px;color:#ef4444;background:none;border:1px solid #ef4444;border-radius:4px;padding:2px 8px;cursor:pointer;">Cancel</button>' : '';

							html += '<tr style="border-bottom:1px solid #f1f5f9;">';
							html += '<td style="padding:10px 6px;">' + w.amount.toFixed(2) + '</td>';
							html += '<td style="padding:10px 6px;">' + w.fee.toFixed(2) + '</td>';
							html += '<td style="padding:10px 6px;font-weight:600;">' + w.net_amount.toFixed(2) + '</td>';
							var statusLabel = statusLabels[w.status] || w.status;
							html += '<td style="padding:10px 6px;"><span style="color:' + statusColor + ';font-weight:600;">' + statusLabel + '</span></td>';
							html += '<td style="padding:10px 6px;">' + txLink + '</td>';
							html += '<td style="padding:10px 6px;font-size:12px;color:#64748b;">' + w.created_at_formatted + '</td>';
							html += '<td style="padding:10px 6px;">' + cancelBtn + '</td>';
							html += '</tr>';

							if (w.status === 'failed' && w.failure_reason) {
								html += '<tr><td colspan="7" style="padding:4px 6px 10px;font-size:11px;color:#ef4444;">Reason: ' + w.failure_reason + '</td></tr>';
							}
						});

						html += '</tbody></table>';
						container.innerHTML = html;
					}, 'json');
				}

				// Load history on page load
				$(document).ready(function() { loadWithdrawalHistory(); });
				</script>
			<?php } ?>
		</div>
		<?php } ?>

