							<div style="flex-shrink:0;">
								<button type="button" id="withdrawal-submit-btn" onclick="submitTRDCWithdrawal()" class="btn btn-mat" style="background:#10b981; color:#fff; border:none; padding:10px 28px; font-size:14px; font-weight:600; border-radius:8px;">
