<script>
function bcToggleFaq(btn) {
    var item = btn.closest('.bc-faq-item');
    var isOpen = item.classList.contains('open');
    document.querySelectorAll('.bc-faq-item.open').forEach(function(el) { el.classList.remove('open'); });
    if (!isOpen) item.classList.add('open');
}
function bcScrollToFaq() {
    var el = document.getElementById('bc-faq');
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function bcSupportSearch() {
    var q = document.getElementById('bc-support-q').value.trim();
    if (!q) return;
    bcScrollToFaq();
}
document.getElementById('bc-support-q').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') bcSupportSearch();
});
</script>
