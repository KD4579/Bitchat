function tag_closePubBox() {
	Wo_HidePosInfo();
	$('.tag_pub_box_progress').fadeOut(100);
	$('.msg_progress').fadeOut(100);
	$('.pub-footer-upper').removeClass('tag_pub_btns_col_smal');
	$('.video-form, .emo-form, .music-form, .map-form, .file-form, .photo-form, .album-form, .feeling-type, .poll-form, .gif-form').slideUp(200);
	$('.all_colors').hide();
	$('.wo_pub_txtara_combo').css("cssText", "");
	$('.postText').css("cssText", "");
	$('#post_color_input').val("");
	$('.publisher-box').removeClass('wo_pub_change_color');
	$(".all_colors_display").removeClass('selected');
}


function bcLoadAdvancedTools() {
	if (window._bcToolsLoaded || window._bcToolsLoading) return;
	window._bcToolsLoading = true;
	var $btn = $('.bc-composer-more-btn');
	$btn.addClass('loading').text('Loading...');
	$.ajax({
		url: Wo_Ajax_Requests_File() + '?f=composer_tools',
		type: 'GET', dataType: 'json',
		success: function(data) {
			if (data && data.status === 200 && data.html) {
				var $tmp = $('<div>').html(data.html);
				var scripts = [];
				$tmp.find('script').each(function() {
					scripts.push(this.textContent);
					$(this).remove();
				});
				var $forms = $tmp.find('.bc-lazy-form-sections').children();
				$('#bc-lazy-tools-container').append($forms);
				var $btns = $tmp.find('.bc-lazy-tool-btns').children();
				$btns.addClass('bc-lazy-injected-btn');
				$btns.insertBefore('.bc-composer-more-btn');
				var $modals = $tmp.find('.bc-lazy-modals').children();
				$('body').append($modals);
				scripts.forEach(function(s) { try { $.globalEval(s); } catch(e) { console.error(e); } });
				window._bcToolsLoaded = true;
				document.querySelector('.pub-footer-upper').classList.add('bc-composer-expanded');
				$btn.removeClass('loading').text('‹ Less');
			}
			window._bcToolsLoading = false;
		},
		error: function() {
			window._bcToolsLoading = false;
			$btn.removeClass('loading').text('••• More');
			$('body').snackbar({ message: 'Could not load tools. Please try again.' });
		}
	});
}
</script>