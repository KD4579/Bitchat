	/* Schedule functions */
	<?php if ($wo['config']['scheduled_posts_enabled'] == '1') { ?>
	window.openScheduleModal = function() {
		var tomorrow = new Date();
		tomorrow.setDate(tomorrow.getDate() + 1);
		var minDate = tomorrow.toISOString().split('T')[0];
		$('#scheduleDate').attr('min', minDate);
		$('#scheduleDate').val('');
		$('#scheduleTime').val('');
		$('#scheduleError').hide();
		$('#schedulePostModal').modal('show');
	};

	window.setScheduledTime = function() {
		var date = $('#scheduleDate').val();
		var time = $('#scheduleTime').val();
		if (!date || !time) {
			$('#scheduleError').text('Please select both date and time').show();
			return;
		}
		var scheduledDateTime = new Date(date + 'T' + time);
		var now = new Date();
		var minTime = new Date(now.getTime() + 60 * 60 * 1000);
		if (scheduledDateTime <= minTime) {
			$('#scheduleError').text('Scheduled time must be at least 1 hour in the future').show();
			return;
		}
		var timestamp = Math.floor(scheduledDateTime.getTime() / 1000);
		$('#scheduledTime').val(timestamp);
		$('#publisher-button').text('Schedule Post');
		var formattedDate = scheduledDateTime.toLocaleString();
		if ($('#schedule-indicator').length == 0) {
			$('#post-textarea').before('<div id="schedule-indicator" class="alert alert-info" style="margin: 10px;"><strong>Scheduled for:</strong> ' + formattedDate + ' <a href="#" onclick="clearSchedule(); return false;" style="margin-left:10px;">Clear</a></div>');
		} else {
			$('#schedule-indicator').html('<strong>Scheduled for:</strong> ' + formattedDate + ' <a href="#" onclick="clearSchedule(); return false;" style="margin-left:10px;">Clear</a>');
		}
		$('#schedulePostModal').modal('hide');
	};

	window.clearSchedule = function() {
		$('#scheduledTime').val('');
		$('#publisher-button').text('<?php echo TextForMode('share'); ?>');
		$('#schedule-indicator').remove();
	};

	/* Handle scheduled post form submission */
	$(document).ajaxSuccess(function(event, xhr, settings) {
		if (settings.url && settings.url.indexOf('f=posts') !== -1) {
			try {
				var response = xhr.responseJSON || JSON.parse(xhr.responseText);
				if (response.scheduled === true && response.status == 200) {
					Wo_ShowNotifications('success', response.message || 'Post scheduled successfully');
					$('#tagPostBox').modal('hide');
					tag_closePubBox();
					$('.postText').val('');
					clearSchedule();
					$('#publisher-button').attr('disabled', false);
					return false;
				}
			} catch(e) {}
		}
	});
	<?php } ?>
})();
