<script type="text/javascript">
/* SM-4: Self-initializing JS for lazy-loaded composer tools */
(function() {
	var allowed = "<?php echo $wo['config']['allowedExtenstion']?>";

	/* Poll form open */
	$('.poll-form-open').click(function () {
		$('.poll-form').slideToggle(200);
