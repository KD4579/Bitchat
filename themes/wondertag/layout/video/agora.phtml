<script type="text/javascript">
(async function() {
var agoraAppId = "<?php echo $wo['config']['agora_chat_app_id'];?>";
var token = "<?php echo $wo['video_call']['access_token'];?>";
var channelName = "<?php echo $wo['video_call']['room'];?>";
var uid = <?php echo $wo['user']['id'];?>;

var client = AgoraRTC.createClient({mode: 'rtc', codec: 'vp8'});
var localAudioTrack = null;
var localVideoTrack = null;
var screenClient = null;
var screenVideoTrack = null;
var screenAudioTrack = null;
var remoteUsers = {};
var mainStreamUid = null;
var screenShareActive = false;

// Remote user published
client.on('user-published', async function(user, mediaType) {
  await client.subscribe(user, mediaType);
  var remoteUid = user.uid;
  remoteUsers[remoteUid] = user;
  console.log("Subscribe remote user successfully: " + remoteUid);

  if (mediaType === 'video') {
    if ($('#full-screen-video').is(':empty')) {
      mainStreamUid = remoteUid;
      user.videoTrack.play('full-screen-video');
      $('#main-stats-btn').show();
      $('#main-stream-stats-btn').show();
    } else {
      addRemoteStreamMiniView(user);
    }
  }
  if (mediaType === 'audio') {
    user.audioTrack.play();
  }
});

client.on('user-unpublished', function(user, mediaType) {
  if (mediaType === 'video' && user.uid === mainStreamUid) {
    // main user stopped video
  }
});

// Remote user left
client.on('user-left', function(user) {
  var remoteUid = user.uid;
  // Stop the remote user's tracks before cleanup
  if (remoteUsers[remoteUid]) {
    if (remoteUsers[remoteUid].videoTrack) {
      remoteUsers[remoteUid].videoTrack.stop();
    }
    if (remoteUsers[remoteUid].audioTrack) {
      remoteUsers[remoteUid].audioTrack.stop();
    }
  }
  delete remoteUsers[remoteUid];

  // Check if any remote users remain
  var remainingUids = Object.keys(remoteUsers);
  if (remainingUids.length === 0) {
    // No remote users left — end the call and redirect
    leaveChannel();
    location.href = "<?php echo($wo['config']['site_url']) ?>";
    return;
  }

  // If the main stream user left, promote another user
  if (remoteUid === mainStreamUid) {
    var nextUid = remainingUids[0];
    var remoteContainerID = '#' + nextUid + '_container';
    $(remoteContainerID).empty().remove();
    $('#full-screen-video').empty();
    if (remoteUsers[nextUid] && remoteUsers[nextUid].videoTrack) {
      remoteUsers[nextUid].videoTrack.play('full-screen-video');
    }
    mainStreamUid = nextUid;
  } else {
    var remoteContainerID = '#' + remoteUid + '_container';
    $(remoteContainerID).empty().remove();
  }
});

// Join channel and publish
try {
  await client.join(agoraAppId, channelName, token, uid);
  console.log("User " + uid + " join channel successfully");

  localAudioTrack = await AgoraRTC.createMicrophoneAudioTrack();
  localVideoTrack = await AgoraRTC.createCameraVideoTrack({
    encoderConfig: '480p_2'
  });

  localVideoTrack.play('local-video', {mirror: true});
  $('.end_vdo_call').removeClass('hidden');

  await client.publish([localAudioTrack, localVideoTrack]);
  console.log("Local tracks published");
} catch (err) {
  console.log("[ERROR] : Agora video call failed", err);
}

// REMOTE STREAMS UI
function addRemoteStreamMiniView(user) {
  var streamId = user.uid;
  $('#remote-streams').append(
    $('<div/>', {'id': streamId + '_container', 'class': 'col-md-3', 'style': 'height:100%'}).append(
      $('<div/>', {'id': streamId + '_mute', 'class': 'mute-overlay'}).append(
        $('<i/>', {'class': 'fas fa-microphone-slash'})
      ),
      $('<div/>', {'id': streamId + '_no-video', 'class': 'no-video-overlay text-center'}).append(
        $('<i/>', {'class': 'fas fa-user'})
      ),
      $('<div/>', {'id': 'agora_remote_' + streamId, 'class': 'remote-video'})
    )
  );
  if (user.videoTrack) {
    user.videoTrack.play('agora_remote_' + streamId);
  }

  var containerId = '#' + streamId + '_container';
  // Swap streams on double-click (desktop) or double-tap (mobile)
  var tapCount = 0;
  var tapTimer = null;
  function swapStream() {
    if (remoteUsers[mainStreamUid] && remoteUsers[mainStreamUid].videoTrack) {
      remoteUsers[mainStreamUid].videoTrack.stop();
      addRemoteStreamMiniView(remoteUsers[mainStreamUid]);
    }
    $(containerId).empty().remove();
    if (user.videoTrack) {
      user.videoTrack.play('full-screen-video');
    }
    mainStreamUid = streamId;
  }
  $(containerId).on('dblclick', swapStream);
  $(containerId).on('touchend', function(e) {
    tapCount++;
    if (tapCount === 1) {
      tapTimer = setTimeout(function() { tapCount = 0; }, 350);
    } else if (tapCount >= 2) {
      clearTimeout(tapTimer);
      tapCount = 0;
      e.preventDefault();
      swapStream();
    }
  });
}

function leaveChannel() {
  if (localAudioTrack) { localAudioTrack.close(); }
  if (localVideoTrack) { localVideoTrack.close(); }
  if (screenShareActive && screenClient) {
    if (screenVideoTrack) { screenVideoTrack.close(); }
    if (screenAudioTrack) { screenAudioTrack.close(); }
    screenClient.leave();
  }
  $.get(Wo_Ajax_Requests_File(), {f:'cancel_call'});
  client.leave().then(function() {
    $("#remote-streams").empty();
  }).catch(function(err) {
    console.log("client leave failed ", err);
  });
}

$(document).on('click', '.end_vdo_call', function(e) {
  leaveChannel();
  location.href = "<?php echo($wo['config']['site_url']) ?>";
});
})();
</script>
