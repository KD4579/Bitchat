<script>
var cpHash = '<?php echo Wo_CreateMainSession(); ?>';
var cpUrl = '<?php echo $wo['config']['site_url']; ?>/requests.php?f=complete_profile';

// ---- EMAIL VERIFICATION ----
function sendEmailCode() {
	var email = document.getElementById('cp_email').value.trim();
	if (!email || !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
		document.getElementById('cp-errors').innerHTML = 'Please enter a valid email address';
		return;
	}
	var btn = document.getElementById('cp-email-btn');
	btn.disabled = true;
	btn.textContent = 'Sending...';
	document.getElementById('cp-errors').innerHTML = '';

	$.post(cpUrl, { action: 'send_email_code', email: email, hash: cpHash }, function(resp) {
		if (resp.status === 200) {
			document.getElementById('cp-step-email').style.display = 'none';
			document.getElementById('cp-step-email-verify').style.display = 'block';
			document.getElementById('cp-sent-email').textContent = email;
			startCountdown('email');
		} else {
			document.getElementById('cp-errors').innerHTML = resp.message || 'Error sending code';
			btn.disabled = false;
			btn.textContent = 'Send Verification Code';
		}
	}, 'json').fail(function() {
		document.getElementById('cp-errors').innerHTML = 'Network error';
		btn.disabled = false;
		btn.textContent = 'Send Verification Code';
	});
}

function verifyEmailCode() {
	var code = document.getElementById('cp_email_code').value.trim();
	if (!code || code.length < 6) {
		document.getElementById('cp-verify-errors').innerHTML = 'Please enter the 6-digit code';
		return;
	}
	var btn = document.getElementById('cp-verify-email-btn');
	btn.disabled = true;
	btn.textContent = 'Verifying...';
	document.getElementById('cp-verify-errors').innerHTML = '';

	$.post(cpUrl, { action: 'verify_email_code', code: code, hash: cpHash }, function(resp) {
		if (resp.status === 200) {
			$('.tag_auth_animation').removeClass('d-none');
			setTimeout(function() {
				window.location.href = '<?php echo $wo['config']['site_url']; ?>/?cache=' + Date.now();
			}, 1200);
		} else {
			document.getElementById('cp-verify-errors').innerHTML = resp.message || 'Invalid code';
			btn.disabled = false;
			btn.textContent = 'Verify & Continue';
		}
	}, 'json').fail(function() {
		btn.disabled = false;
		btn.textContent = 'Verify & Continue';
	});
}

// ---- PHONE VERIFICATION ----
function sendPhoneCode() {
	var phone = document.getElementById('cp_phone').value.trim();
	if (!phone || !phone.match(/^\+?\d{7,15}$/)) {
		document.getElementById('cp-errors').innerHTML = 'Please enter a valid phone number (e.g. +1234567890)';
		return;
	}
	var btn = document.getElementById('cp-phone-btn');
	btn.disabled = true;
	btn.textContent = 'Sending...';
	document.getElementById('cp-errors').innerHTML = '';

	$.post(cpUrl, { action: 'send_phone_code', phone: phone, hash: cpHash }, function(resp) {
		if (resp.status === 200) {
			document.getElementById('cp-step-phone').style.display = 'none';
			document.getElementById('cp-step-phone-verify').style.display = 'block';
			document.getElementById('cp-sent-phone').textContent = phone;
			startCountdown('phone');
		} else {
			document.getElementById('cp-errors').innerHTML = resp.message || 'Error sending code';
			btn.disabled = false;
			btn.textContent = 'Send SMS Code';
		}
	}, 'json').fail(function() {
		document.getElementById('cp-errors').innerHTML = 'Network error';
		btn.disabled = false;
		btn.textContent = 'Send SMS Code';
	});
}

function verifyPhoneCode() {
	var code = document.getElementById('cp_phone_code').value.trim();
	if (!code || code.length < 5) {
		document.getElementById('cp-verify-errors').innerHTML = 'Please enter the 5-digit SMS code';
		return;
	}
	var btn = document.getElementById('cp-verify-phone-btn');
	btn.disabled = true;
	btn.textContent = 'Verifying...';
	document.getElementById('cp-verify-errors').innerHTML = '';

	$.post(cpUrl, { action: 'verify_phone_code', code: code, hash: cpHash }, function(resp) {
		if (resp.status === 200) {
			$('.tag_auth_animation').removeClass('d-none');
			setTimeout(function() {
				window.location.href = '<?php echo $wo['config']['site_url']; ?>/?cache=' + Date.now();
			}, 1200);
		} else {
			document.getElementById('cp-verify-errors').innerHTML = resp.message || 'Invalid code';
			btn.disabled = false;
			btn.textContent = 'Verify & Continue';
		}
	}, 'json').fail(function() {
		btn.disabled = false;
		btn.textContent = 'Verify & Continue';
	});
}

// ---- COUNTDOWN TIMER ----
function startCountdown(type) {
	var seconds = 60;
	var countdownEl = document.getElementById('cp-' + type + '-countdown');
	var timerEl = document.getElementById('cp-' + type + '-timer');
	var resendEl = document.getElementById('cp-' + type + '-resend');

	timerEl.style.display = '';
	resendEl.style.display = 'none';

	var interval = setInterval(function() {
		seconds--;
		countdownEl.textContent = seconds;
		if (seconds <= 0) {
			clearInterval(interval);
			timerEl.style.display = 'none';
			resendEl.style.display = '';
		}
	}, 1000);
}
</script>
