<script>
// Auto-update location when visiting nearby page (1-hour refresh)
if (navigator.geolocation) {
	navigator.geolocation.getCurrentPosition(function(position) {
		Wo_UpdateLocation(position, 'nearby_page', function(data) {
			Wo_LoadNearByUsers();
			if (typeof map !== 'undefined' && data.lat && data.lng) {
				map.setView([data.lat, data.lng], 7);
			}
		});
	});
}

function Wo_RefreshMyLocation(btn) {
	if (!navigator.geolocation) {
		alert('Geolocation is not supported by your browser');
		return;
	}
	var $btn = $(btn);
	$btn.prop('disabled', true).find('span').text('Updating...');
	navigator.geolocation.getCurrentPosition(function(position) {
		Wo_UpdateLocation(position, 'nearby_page', function(data) {
			Wo_LoadNearByUsers();
			if (typeof map !== 'undefined' && data.lat && data.lng) {
				map.setView([data.lat, data.lng], 7);
			}
			$btn.prop('disabled', false).find('span').text('Refresh');
		});
	}, function(error) {
		$btn.prop('disabled', false).find('span').text('Refresh');
		alert('Unable to retrieve your location');
	});
}

$('.tag_onboard_btn').click(function() {
	if ($("body").hasClass("onboard_done")) {
		$('body').toggleClass('onboard_done');
		localStorage.removeItem('tagOnboarding');
		localStorage.tagOnboarding = "onboard";
	} else {
		$('body').toggleClass('onboard_done');
		localStorage.removeItem('tagOnboarding');
		localStorage.tagOnboarding = "onboard_done";
	}
});

jQuery(document).ready(function($) {
/*Map*/
var planes = [];
var markersMap = {};
<?php foreach ($nearby_users as $user) : ?>
planes.push({
	name: '<?php echo addslashes($user['user_data']['name'])?>',
	lat: <?php echo $user['user_data']['lat']?>,
	lng: <?php echo $user['user_data']['lng']?>,
	user_id: <?php echo $user['user_data']['id']?>,
	avatar: '<?php echo addslashes($user['user_data']['avatar'])?>',
	online: <?php echo ($user['user_data']['lastseen'] > (time() - 60)) ? 'true' : 'false'; ?>
});
<?php endforeach; ?>
var map = L.map('map').setView([<?php echo $wo['user']['lat']?>, <?php echo $wo['user']['lng']?>], 7);

L.tileLayer(
	'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
		attribution: '',
		maxZoom: 18,
	}).addTo(map);

function createMarkerIcon(avatarUrl, isOnline) {
	var borderColor = isOnline ? '#22c55e' : '#e2e8f0';
	var dotColor = isOnline ? '#22c55e' : '#94a3b8';
	return L.divIcon({
		className: 'nearby-map-marker',
		html: '<div style="position:relative;width:36px;height:36px;">' +
			'<img src="' + avatarUrl + '" style="width:36px;height:36px;border-radius:50%;border:2px solid ' + borderColor + ';object-fit:cover;" onerror="this.src=\'<?php echo $wo['config']['theme_url'];?>/img/d-avatar.jpg\'">' +
			'<div style="position:absolute;bottom:0;right:0;width:10px;height:10px;background:' + dotColor + ';border:2px solid white;border-radius:50%;"></div></div>',
		iconSize: [36, 36],
		iconAnchor: [18, 18],
		popupAnchor: [0, -20]
	});
}

for (var i = 0; i < planes.length; i++) {
	var icon = createMarkerIcon(planes[i].avatar, planes[i].online);
	var marker = L.marker([planes[i].lat, planes[i].lng], {icon: icon})
		.bindPopup(planes[i].name)
		.addTo(map);
	markersMap[planes[i].user_id] = marker;
}

// Socket.io live map integration
if (typeof socket !== 'undefined' && socket !== null) {
	socket.emit('join_nearby_page', { user_id: _getCookie('user_id') });

	socket.on('nearby_user_online', function(data) {
		if (!data.user_id || !data.lat || !data.lng) return;
		if (markersMap[data.user_id]) {
			markersMap[data.user_id].setLatLng([data.lat, data.lng]);
			markersMap[data.user_id].setIcon(createMarkerIcon(data.avatar || '', true));
		} else {
			var icon = createMarkerIcon(data.avatar || '', true);
			var m = L.marker([data.lat, data.lng], {icon: icon})
				.bindPopup(data.name || 'User')
				.addTo(map);
			markersMap[data.user_id] = m;
		}
	});

	socket.on('nearby_user_moved', function(data) {
		if (!data.user_id || !data.lat || !data.lng) return;
		if (markersMap[data.user_id]) {
			markersMap[data.user_id].setLatLng([data.lat, data.lng]);
			markersMap[data.user_id].setIcon(createMarkerIcon(data.avatar || '', true));
		} else {
			var icon = createMarkerIcon(data.avatar || '', true);
			var m = L.marker([data.lat, data.lng], {icon: icon})
				.bindPopup(data.name || 'User')
				.addTo(map);
			markersMap[data.user_id] = m;
		}
	});

	socket.on('nearby_user_offline', function(data) {
		if (!data.user_id) return;
		if (markersMap[data.user_id]) {
			markersMap[data.user_id].setIcon(createMarkerIcon('', false));
		}
	});

	$(window).on('beforeunload', function() {
		socket.emit('leave_nearby_page', { user_id: _getCookie('user_id') });
	});
	$(document).on('click', 'a[data-ajax]', function() {
		socket.emit('leave_nearby_page', { user_id: _getCookie('user_id') });
	});
}
});

