<script>
(function() {
    // Fetch live BTC price for hero stat
    fetch('https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT')
        .then(r => r.json())
        .then(d => {
            const el = document.getElementById('bc-hero-btc');
            if (el && d.price) {
                el.textContent = '$' + parseFloat(d.price).toLocaleString('en-US', {maximumFractionDigits: 0});
            }
        })
        .catch(() => {});
})();
</script>
