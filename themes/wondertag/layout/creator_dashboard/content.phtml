<script>
$('#enable-creator-btn').on('click', function() {
    var btn = $(this);
    btn.prop('disabled', true).text('Enabling...');
    $.post(Wo_Ajax_Requests_File() + '?f=creator', {
        action: 'enable'
    }, function(data) {
        if (data.status == 200) {
            window.location.reload();
        } else {
            Wo_ShowNotifications('error', data.message || 'Failed to enable creator mode');
            btn.prop('disabled', false).text('Enable Creator Mode');
        }
    }, 'json');
});

$('#disable-creator-btn').on('click', function() {
    if (!confirm('Are you sure you want to disable creator mode? You will lose the creator badge.')) return;
    var btn = $(this);
    btn.prop('disabled', true).text('Disabling...');
    $.post(Wo_Ajax_Requests_File() + '?f=creator', {
        action: 'disable'
    }, function(data) {
        if (data.status == 200) {
            window.location.reload();
        } else {
            Wo_ShowNotifications('error', data.message || 'Failed to disable creator mode');
            btn.prop('disabled', false).text('Disable Creator Mode');
        }
    }, 'json');
});
</script>
