<script>
function bcEnableCreatorMode(btn) {
    btn.disabled = true;
    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="30 70"/></svg> Enabling...';
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'enable' },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                window.location.reload();
            } else {
                alert(data.message || 'Failed to enable creator mode');
                btn.disabled = false;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> Enable Creator Mode';
            }
        },
        error: function() {
            alert('Request failed');
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> Enable Creator Mode';
        }
    });
}

function bcDisableCreatorMode(btn) {
    if (!confirm('Are you sure you want to disable creator mode? You will lose the creator badge.')) return;
    btn.disabled = true;
    btn.textContent = 'Disabling...';
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'disable' },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                window.location.reload();
            } else {
                alert(data.message || 'Failed to disable creator mode');
                btn.disabled = false;
                btn.textContent = 'Disable Creator Mode';
            }
        },
        error: function() {
            alert('Request failed');
            btn.disabled = false;
            btn.textContent = 'Disable Creator Mode';
        }
    });
}

function bcLoadMoreRewards(btn) {
    var offset = parseInt($(btn).attr('data-offset')) || 10;
    $(btn).prop('disabled', true).text('Loading...');
    $.get(Wo_Ajax_Requests_File(), { f: 'creator', action: 'load_rewards', offset: offset }, function(data) {
        if (data.status == 200 && data.html) {
            $('#bc-reward-history').append(data.html);
            if (data.has_more) {
                $(btn).attr('data-offset', offset + 10).prop('disabled', false).text('Load More');
            } else {
                $('#bc-rh-load-more').remove();
            }
        } else {
            $('#bc-rh-load-more').remove();
        }
    }, 'json').fail(function() { $(btn).prop('disabled', false).text('Load More'); });
}
</script>
