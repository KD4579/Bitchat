<script>
function bcWelcomeGoStep(step) {
	document.getElementById('bc-welcome-step-1').style.display = 'none';
	document.getElementById('bc-welcome-step-2').style.display = 'none';
	document.getElementById('bc-welcome-step-3').style.display = 'none';
	document.getElementById('bc-welcome-step-' + step).style.display = 'block';
	var steps = document.querySelectorAll('.bc-welcome-step');
	steps.forEach(function(s) {
		var sNum = parseInt(s.getAttribute('data-step'));
		s.classList.toggle('active', sNum <= step);
		s.classList.toggle('done', sNum < step);
	});
}

// Avatar upload
document.getElementById('bc-avatar-input').addEventListener('change', function(e) {
	var file = e.target.files[0];
	if (!file) return;
	// Preview
	var reader = new FileReader();
	reader.onload = function(ev) {
		document.getElementById('bc-avatar-img').src = ev.target.result;
	};
	reader.readAsDataURL(file);
	// Upload
	var fd = new FormData();
	fd.append('avatar', file);
	fd.append('user_id', '<?php echo $wo['user']['user_id']; ?>');
	$.ajax({
		url: '<?php echo $wo['config']['site_url']; ?>/requests.php?f=update_user_avatar_picture',
		type: 'POST',
		data: fd,
		processData: false,
		contentType: false,
		dataType: 'json',
		success: function(data) {
			if (data.status == 200) {
				document.getElementById('bc-step1-next').textContent = 'Next';
			}
		}
	});
});

function bcWelcomeFollow(userId, btn) {
	btn.textContent = 'Following';
	btn.disabled = true;
	btn.classList.add('bc-followed');
	if (typeof Wo_FollowUser === 'function') {
		Wo_FollowUser(userId);
	}
}

function bcWelcomeFollowAll() {
	document.querySelectorAll('.bc-welcome-follow-btn:not(.bc-followed)').forEach(function(btn) {
		btn.click();
	});
}

function bcWelcomeComplete() {
	$.post('<?php echo $wo['config']['site_url']; ?>/requests.php?f=onboarding', {
		action: 'complete',
		hash_id: $('input[name=hash_id]').val()
	}, function(data) {
		window.location.href = '<?php echo $wo['config']['site_url']; ?>';
	}, 'json').fail(function() {
		window.location.href = '<?php echo $wo['config']['site_url']; ?>';
	});
}
</script>
