<script>
var selectedMethod = null;
var selectedDays = 0;
var selectedApy = 0;

function selectStakingMethod(method) {
	selectedMethod = method;

	// Reset card styles
	$('#card-onchain').css({'border-color':'#e2e8f0','box-shadow':'none'});
	$('#card-offchain').css({'border-color':'#e2e8f0','box-shadow':'none'});

	if (method === 'onchain') {
		$('#card-onchain').css({'border-color':'#f59e0b','box-shadow':'0 0 0 3px rgba(245,158,11,0.15)'});
		$('#offchain-staking-panel').slideUp(300);

		// Onchain: redirect to wallet connect
		if (typeof window.ethereum !== 'undefined') {
			connectWalletForStaking();
		} else {
			Wo_Confirm('MetaMask or a Web3 wallet is required for onchain staking. Please install MetaMask extension or use a Web3-enabled browser.', function(){
				window.open('https://metamask.io/download/', '_blank');
			});
		}
	} else {
		$('#card-offchain').css({'border-color':'#3b82f6','box-shadow':'0 0 0 3px rgba(59,130,246,0.15)'});
		$('#offchain-staking-panel').slideDown(300);
	}
}

async function connectWalletForStaking() {
	try {
		const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
		if (accounts && accounts.length > 0) {
			// Check if on BSC (chain ID 56)
			const chainId = await window.ethereum.request({ method: 'eth_chainId' });
			if (chainId !== '0x38') {
				try {
					await window.ethereum.request({
						method: 'wallet_switchEthereumChain',
						params: [{ chainId: '0x38' }]
					});
				} catch (switchError) {
					if (switchError.code === 4902) {
						await window.ethereum.request({
							method: 'wallet_addEthereumChain',
							params: [{
								chainId: '0x38',
								chainName: 'BNB Smart Chain',
								nativeCurrency: { name: 'BNB', symbol: 'BNB', decimals: 18 },
								rpcUrls: ['https://bsc-dataseed.binance.org/'],
								blockExplorerUrls: ['https://bscscan.com/']
							}]
						});
					} else {
						alert('Please switch to BNB Smart Chain to continue.');
						return;
					}
				}
			}
			alert('Wallet connected: ' + accounts[0].substring(0, 6) + '...' + accounts[0].substring(38) + '\n\nOnchain staking smart contract integration coming soon!');
		}
	} catch (err) {
		alert('Wallet connection failed: ' + (err.message || err));
	}
}

// Offchain staking plan selection
$('#staking-plans input[name="lock_days"]').on('change', function() {
	selectedDays = parseInt($(this).val());
	selectedApy = parseFloat($(this).closest('.staking-plan-option').data('apy'));
	updateRewardPreview();
});

$('#stake-amount').on('input', function() {
	updateRewardPreview();
});

function updateRewardPreview() {
	var amount = parseFloat($('#stake-amount').val()) || 0;
	if (amount >= 100 && selectedDays > 0) {
		var reward = amount * (selectedApy / 100) * (selectedDays / 365);
		var unlockDate = new Date();
		unlockDate.setDate(unlockDate.getDate() + selectedDays);

		$('#preview-amount').text(amount.toLocaleString(undefined, {maximumFractionDigits:2}) + ' TRDC');
		$('#preview-apy').text(selectedApy + '%');
		$('#preview-reward').text('+' + reward.toFixed(2) + ' TRDC');
		$('#preview-unlock').text(unlockDate.toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}));
		$('#reward-preview').slideDown(200);
		$('#btn-stake-offchain').prop('disabled', false).css('opacity', '1');
	} else {
		$('#reward-preview').slideUp(200);
		$('#btn-stake-offchain').prop('disabled', true).css('opacity', '0.5');
	}
}

function submitOffchainStake() {
	var amount = parseFloat($('#stake-amount').val()) || 0;
	if (amount < 100) {
		alert('Minimum stake amount is 100 TRDC');
		return;
	}
	if (selectedDays <= 0) {
		alert('Please select a staking period');
		return;
	}

	var reward = amount * (selectedApy / 100) * (selectedDays / 365);

	if (!confirm('Confirm staking ' + amount.toLocaleString() + ' TRDC for ' + selectedDays + ' days at ' + selectedApy + '% APY?\n\nEstimated reward: +' + reward.toFixed(2) + ' TRDC\n\nYour TRDC will be locked until the unlock date.')) {
		return;
	}

	$('#btn-stake-offchain').prop('disabled', true).text('Processing...');

	$.post(Wo_Ajax_Requests_File() + '?f=staking', {
		action: 'create_offchain',
		amount: amount,
		lock_days: selectedDays
	}, function(data) {
		if (data.status === 200) {
			alert(data.message);
			window.location.reload();
		} else {
			alert(data.message || 'Staking failed. Please try again.');
			$('#btn-stake-offchain').prop('disabled', false).text('Confirm Stake');
		}
	}, 'json').fail(function() {
		alert('Network error. Please try again.');
		$('#btn-stake-offchain').prop('disabled', false).text('Confirm Stake');
	});
}
</script>
