<script>
function bcLbTab(btn, panel) {
    document.querySelectorAll('.bc-lb-tab').forEach(function(t) { t.classList.remove('bc-lb-tab-active'); });
    document.querySelectorAll('.bc-lb-panel').forEach(function(p) { p.classList.remove('bc-lb-panel-active'); });
    btn.classList.add('bc-lb-tab-active');
    document.getElementById('bc-lb-' + panel).classList.add('bc-lb-panel-active');
}
</script>
