<script>
function bcLbTab(btn, panel) {
    document.querySelectorAll('.bc-lb-tab').forEach(function(t) { t.classList.remove('bc-lb-tab-active'); });
    document.querySelectorAll('.bc-lb-panel').forEach(function(p) { p.classList.remove('bc-lb-panel-active'); });
    btn.classList.add('bc-lb-tab-active');
    document.getElementById('bc-lb-' + panel).classList.add('bc-lb-panel-active');
    if (panel === 'traders') { bcLoadTradex24Traders(); }
}

var _tradex24Loaded = false;
function bcLoadTradex24Traders() {
    if (_tradex24Loaded) return;
    _tradex24Loaded = true;
    // Placeholder — swap URL for real Tradex24 leaderboard API once live
    var apiUrl = 'https://tradex24.com/api/public/leaderboard/traders?ref=bitchat';
    var el = document.getElementById('bc-lb-traders-inner');
    fetch(apiUrl, { signal: AbortSignal.timeout ? AbortSignal.timeout(5000) : undefined })
        .then(function(r){ return r.json(); })
        .then(function(data){
            if (!data || !data.traders || !data.traders.length) { return; }
            var html = '';
            data.traders.forEach(function(t, i) {
                html += '<div class="bc-lb-row">'
                    + '<div class="bc-lb-rank"><span class="bc-lb-rank-num">' + (t.rank||i+1) + '</span></div>'
                    + '<div class="bc-lb-user" style="flex:1;padding:10px 0;">'
                    + '<div class="bc-lb-info"><span class="bc-lb-name">' + (t.displayName||'Trader') + '</span>'
                    + '<span style="font-size:11px;color:#94a3b8;margin-left:6px;">' + (t.orders||0) + ' orders</span></div>'
                    + '</div>'
                    + '<div class="bc-lb-metric"><span class="bc-lb-metric-val">' + Number(t.volume||0).toLocaleString(undefined,{maximumFractionDigits:0}) + '</span>'
                    + '<span class="bc-lb-metric-label">TRDC vol</span></div></div>';
            });
            el.innerHTML = html;
        })
        .catch(function(){ /* API not live yet — keep placeholder */ });
}
</script>
