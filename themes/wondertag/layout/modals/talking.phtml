<?php if ($wo['config']['agora_chat_video'] == 1) { ?>
  <script type="text/javascript">
    (function() {
    var agoraAppId = "<?php echo $wo['config']['agora_chat_app_id'];?>";
    var token = "<?php echo $wo['incall']['access_token'];?>";
    var channelName = "<?php echo $wo['incall']['room'];?>";
    var uid = <?php echo $wo['user']['id'];?>;
    var localAudioTrack = null;
    var agoraClient = null;

    function showStatus(msg, type) {
      type = type || 'info';
      $('#remote-media').html('<div class="alert alert-' + type + '">' + msg + '</div>');
    }

    if (typeof AgoraRTC === 'undefined') {
      showStatus('Agora SDK not loaded. Please refresh the page.', 'danger');
      return;
    }

    if (!token || token === '') {
      showStatus('No access token available.', 'danger');
      return;
    }

    showStatus('Connecting to audio...');

    var callConnected = false;
    var connectionTimeout = setTimeout(function() {
      if (!callConnected) {
        showStatus('Connection timed out. Please try again.', 'warning');
      }
    }, 20000);

    async function startAudioCall() {
      try {
        agoraClient = AgoraRTC.createClient({mode: 'rtc', codec: 'vp8'});

        agoraClient.on('user-published', async function(user, mediaType) {
          await agoraClient.subscribe(user, mediaType);
          if (mediaType === 'audio') {
            callConnected = true;
            clearTimeout(connectionTimeout);
            $('#remote-media').html('<div class="alert alert-success">Audio connected</div>');
            user.audioTrack.play();
          }
        });

        agoraClient.on('user-unpublished', function(user, mediaType) {
          if (mediaType === 'audio') {
            showStatus('Other user muted audio.', 'warning');
          }
        });

        agoraClient.on('user-left', function(user) {
          leaveChannel();
        });

        showStatus('Joining channel...');
        await agoraClient.join(agoraAppId, channelName, token, uid);
        console.log("User " + uid + " joined channel successfully");
        showStatus('Connected. Waiting for other user...');

        localAudioTrack = await AgoraRTC.createMicrophoneAudioTrack();
        await agoraClient.publish([localAudioTrack]);
        console.log("Local audio track published");
      } catch (err) {
        console.log("[ERROR] Agora audio call failed:", err);
        clearTimeout(connectionTimeout);
        var msg = err.message || err.info || JSON.stringify(err);
        if (msg.indexOf('Permission') !== -1 || msg.indexOf('NotAllowed') !== -1) {
          showStatus('Microphone access denied. Please allow microphone access.', 'danger');
        } else {
          showStatus('Call failed: ' + msg, 'danger');
        }
      }
    }

    function leaveChannel() {
      clearTimeout(connectionTimeout);
      if (localAudioTrack) {
        localAudioTrack.close();
        localAudioTrack = null;
      }
      // Clean up database call record before leaving
      $.get(Wo_Ajax_Requests_File(), {f:'cancel_call'});
      if (agoraClient) {
        agoraClient.leave().catch(function(){}).then(function() {
          $('#re-talking-modal').remove();
          $('.modal-backdrop').remove();
          $('body').removeClass('modal-open');
          location.href = "<?php echo($wo['config']['site_url']) ?>";
        });
      } else {
        $('#re-talking-modal').remove();
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open');
        location.href = "<?php echo($wo['config']['site_url']) ?>";
      }
    }

    $(document).on('click', '.decline-call', function(e) {
      e.preventDefault();
      e.stopPropagation();
      leaveChannel();
      return false;
    });

    startAudioCall();
    })();
  </script>
<?php }else{ ?>
<script>
navigator.getUserMedia = navigator.getUserMedia || navigator.webkitGetUserMedia || navigator.mozGetUserMedia || navigator.msGetUserMedia;
if (!navigator.getUserMedia) {
  $('#remote-media').html('<div class="alert alert-danger">Sorry, WebRTC is not available in your browser.</div>');
}

Twilio.Video.connect('<?php echo $wo['incall']['access_token'];?>', { name: '<?php echo $wo['incall']['room'];?>', audio: true, video: false }).then(room => {
  console.log('Connected to Room "%s"', room.name);
 
  room.participants.forEach(participantConnected);
  room.on('participantConnected', participantConnected);
  room.on('disconnected', room => {
    // Detach the local media elements
    room.localParticipant.tracks.forEach(publication => {
      const attachedElements = publication.track.detach();
      attachedElements.forEach(element => element.remove());
	  $.get(Wo_Ajax_Requests_File(), {f:'cancel_call'}, function (data) {});
      location.href = "<?php echo($wo['config']['site_url']) ?>";
    });
  });
  room.on('participantDisconnected', function(participant) {
    console.log(participant.identity + ' left the Room');
    $.get(Wo_Ajax_Requests_File(), {f:'cancel_call'}, function (data) {});
    location.href = "<?php echo($wo['config']['site_url']) ?>";
  });

  $(document).on('click', 'a[data-ajax]', function(e) {
	  $.get(Wo_Ajax_Requests_File(), {f:'cancel_call'}, function (data) {});
      room.disconnect();
  });
  $(document).on('click', '.decline-call', function(e) {
	  $.get(Wo_Ajax_Requests_File(), {f:'cancel_call'}, function (data) {});
      room.disconnect();
  });
});
 
function participantConnected(participant) {
  console.log('Participant "%s" connected', participant.identity);
 
  const div = document.createElement('div');
  div.id = participant.sid;
  //div.innerText = participant.identity;
  participant.tracks.forEach(publication => {
    if (publication.isSubscribed) {
      const track = publication.track;
      div.appendChild(track.attach());
    }
  });
  participant.on('trackSubscribed', track => {
    /*$('#remote-media').html('');*/
    document.getElementById('remote-media').appendChild(track.attach());
  });
 
  $('#remote-media').html(div);
}
</script>
<?php } ?>