<script>
function bcSaveTradex24Id() {
    var uid = document.getElementById('tradex24-uid-input').value.trim();
    var hash_id = '<?php echo Wo_CreateSession(); ?>';
    var user_id = '<?php echo intval($wo["setting"]["user_id"]); ?>';
    $.post(Wo_Ajax_Requests_File() + '?f=update_socialinks_setting', {
        user_id: user_id,
        hash_id: hash_id,
        tradex24_user_id: uid
    }, function(data) {
        if (data.status == 200) {
            $('#tradex24-link-alert').html('<div class="alert alert-success" style="padding:6px 12px;font-size:12px;margin-bottom:8px;">Saved!</div>');
            setTimeout(function(){ $('#tradex24-link-alert').empty(); }, 2500);
        } else {
            $('#tradex24-link-alert').html('<div class="alert alert-danger" style="padding:6px 12px;font-size:12px;margin-bottom:8px;">Could not save — please try again.</div>');
        }
    });
}
</script>
