<script>
function bcLbTab(btn, panel) {
    document.querySelectorAll('.bc-lb-tab').forEach(function(t){t.classList.remove('bc-lb-tab-active');t.classList.add('btn-default');t.classList.remove('btn-main');});
    document.querySelectorAll('.bc-lb-panel').forEach(function(p){p.style.display='none';});
    btn.classList.add('bc-lb-tab-active','btn-main');btn.classList.remove('btn-default');
    var el = document.getElementById('bc-lb-'+panel);
    if (el) el.style.display='block';
    if (panel === 'traders') { bcLoadTradex24Traders(); }
}
var _tradex24Loaded = false;
function bcLoadTradex24Traders() {
    if (_tradex24Loaded) return; _tradex24Loaded = true;
    fetch('https://tradex24.com/api/public/leaderboard/traders?ref=bitchat', { signal: AbortSignal.timeout ? AbortSignal.timeout(5000) : undefined })
        .then(function(r){ return r.json(); })
        .then(function(data){
            if (!data||!data.traders||!data.traders.length) return;
            var html='';
            data.traders.forEach(function(t,i){
                html+='<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f1f5f9;">'
                    +'<div style="width:30px;text-align:center;font-weight:700;color:#64748b;">'+(i+1)+'</div>'
                    +'<div style="flex:1;font-weight:600;">'+(t.display_name||t.username||'Trader')+'</div>'
                    +'<div style="text-align:right;"><div style="font-weight:700;">'+(t.volume_trdc||0)+'</div><div style="font-size:11px;color:#94a3b8;">TRDC vol</div></div></div>';
            });
            document.getElementById('bc-lb-traders-inner').innerHTML=html;
        }).catch(function(){});
}
</script>
