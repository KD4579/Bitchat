<?php
global $wo, $sqlConnect;

// === KEY METRICS ===
$now = time();
$day_ago = $now - 86400;
$today = date('Y-m-d');

// Daily Active Users (last 24h)
$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE `lastseen` > {$day_ago} AND `src` != 'Fake'");
$dau = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

// New Users Today
$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE DATE(`registered`) = '{$today}' AND `src` != 'Fake'");
$new_today = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

// Posts Today
$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_POSTS . " WHERE `time` > {$day_ago}");
$posts_today = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

// Referral Joins (7d)
$week_ago = date('Y-m-d', strtotime('-7 days'));
$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE `referrer` > 0 AND `registered` >= '{$week_ago}' AND `src` != 'Fake'");
$ref_7d = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

// === 7-DAY GROWTH CHART ===
$daily_users = array();
$max_daily = 1;
for ($i = 6; $i >= 0; $i--) {
    $d = date('Y-m-d', strtotime("-{$i} days"));
    $q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE DATE(`registered`) = '{$d}' AND `src` != 'Fake'");
    $count = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;
    $daily_users[] = array('date' => $d, 'label' => date('D', strtotime($d)), 'count' => $count);
    if ($count > $max_daily) $max_daily = $count;
}

// === TRDC ECONOMY ===
$q = mysqli_query($sqlConnect, "SELECT COALESCE(SUM(`wallet`), 0) as total FROM " . T_USERS);
$trdc_total = ($r = mysqli_fetch_assoc($q)) ? floatval($r['total']) : 0;

$trdc_issued_today = 0;
$q_check = mysqli_query($sqlConnect, "SHOW TABLES LIKE 'Wo_TRDC_Rewards'");
if (mysqli_num_rows($q_check) > 0) {
    $today_start = strtotime('today midnight');
    $today_end   = $today_start + 86400;
    $q = mysqli_query($sqlConnect, "SELECT COALESCE(SUM(`amount`), 0) as total FROM Wo_TRDC_Rewards WHERE `created_at` >= {$today_start} AND `created_at` < {$today_end}");
    $trdc_issued_today = ($r = mysqli_fetch_assoc($q)) ? floatval($r['total']) : 0;
}

// Top 5 TRDC holders
$top_earners = array();
$q = mysqli_query($sqlConnect, "SELECT `user_id`, `username`, `wallet`, `avatar` FROM " . T_USERS . " WHERE `wallet` > 0 AND `src` != 'Fake' ORDER BY `wallet` DESC LIMIT 5");
while ($r = mysqli_fetch_assoc($q)) { $top_earners[] = $r; }

// === ENGAGEMENT HEALTH ===
$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM Wo_Reactions WHERE `time` > {$day_ago}");
$reactions_today = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM Wo_Comments WHERE `time` > {$day_ago}");
$comments_today = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

$q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM Wo_UserStory WHERE `expire` > UNIX_TIMESTAMP()");
$stories_active = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;

// === REFERRAL CHART (7d) ===
$daily_refs = array();
$max_ref = 1;
for ($i = 6; $i >= 0; $i--) {
    $d = date('Y-m-d', strtotime("-{$i} days"));
    $q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE `referrer` > 0 AND DATE(`registered`) = '{$d}'");
    $count = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;
    $daily_refs[] = array('date' => $d, 'label' => date('D', strtotime($d)), 'count' => $count);
    if ($count > $max_ref) $max_ref = $count;
}

// === GHOST ACTIVITY STATS ===
$ghost_today = 0;
$q_check = mysqli_query($sqlConnect, "SHOW TABLES LIKE 'Wo_Ghost_Queue'");
if (mysqli_num_rows($q_check) > 0) {
    $q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM Wo_Ghost_Queue WHERE `status` = 'executed' AND DATE(`executed_at`) = '{$today}'");
    $ghost_today = ($r = mysqli_fetch_assoc($q)) ? (int)$r['c'] : 0;
}
