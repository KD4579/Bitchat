<script>
$('#feed-algorithm-form').on('submit', function(e) {
    e.preventDefault();
    var form = $(this);
    var weights = JSON.stringify({
        engagement: parseFloat(form.find('[name=w_engagement]').val()) || 1.0,
        comments: parseFloat(form.find('[name=w_comments]').val()) || 2.0,
        shares: parseFloat(form.find('[name=w_shares]').val()) || 1.5,
        media_bonus: parseFloat(form.find('[name=w_media_bonus]').val()) || 2.0,
        freshness_decay: parseFloat(form.find('[name=w_freshness_decay]').val()) || 0.95,
        pro_boost: parseFloat(form.find('[name=w_pro_boost]').val()) || 3.0,
        spam_penalty: parseFloat(form.find('[name=w_spam_penalty]').val()) || 5.0,
        link_penalty: parseFloat(form.find('[name=w_link_penalty]').val()) || 2.0,
        frequency_penalty: parseFloat(form.find('[name=w_frequency_penalty]').val()) || 3.0
    });
    $.post(Wo_Ajax_Requests_File() + '?f=feed_algorithm', {
        feed_algorithm_enabled: form.find('[name=feed_algorithm_enabled]').val(),
        feed_weights: weights,
        feed_candidate_pool: form.find('[name=feed_candidate_pool]').val(),
        feed_max_same_user: form.find('[name=feed_max_same_user]').val(),
        feed_spam_window_hours: form.find('[name=feed_spam_window_hours]').val()
    }, function(data) {
        if (data.status == 200) {
            Wo_ShowNotifications('success', 'Settings saved successfully');
        } else {
            Wo_ShowNotifications('error', data.message || 'Failed to save settings');
        }
    }, 'json');
});
</script>
