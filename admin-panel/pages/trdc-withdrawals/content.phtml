<script>
var hash_id = '<?php echo Wo_CreateSession(); ?>';

function saveWithdrawalSettings() {
    var formData = $('#withdrawal-settings-form').serializeArray();
    formData.push({name: 'hash_id', value: hash_id});
    $.post(Wo_Ajax_Requests_File() + '?f=admin_setting&s=save_withdrawal_settings', $.param(formData), function(data) {
        if (data.status == 200) {
            $('#settings-save-status').html('<span style="color:#10b981;">Saved!</span>');
            setTimeout(function() { $('#settings-save-status').html(''); }, 3000);
        } else {
            $('#settings-save-status').html('<span style="color:#ef4444;">' + (data.message || 'Error') + '</span>');
        }
    }, 'json');
}

function approveWithdrawal(id) {
    if (!confirm('Approve withdrawal #' + id + '? The processor will send tokens to the user\'s wallet.')) return;
    $.get(Wo_Ajax_Requests_File(), {f: 'admin_setting', s: 'approve_withdrawal', withdrawal_id: id, hash_id: hash_id}, function(data) {
        if (data.status == 200) {
            $('#withdrawal-row-' + id).fadeOut(300, function() { $(this).remove(); });
        } else {
            alert(data.message || 'Error');
        }
    }, 'json');
}

function rejectWithdrawal(id) {
    var note = prompt('Rejection reason (optional):');
    if (note === null) return;
    $.get(Wo_Ajax_Requests_File(), {f: 'admin_setting', s: 'reject_withdrawal', withdrawal_id: id, admin_note: note, hash_id: hash_id}, function(data) {
        if (data.status == 200) {
            $('#withdrawal-row-' + id).fadeOut(300, function() { $(this).remove(); });
        } else {
            alert(data.message || 'Error');
        }
    }, 'json');
}

function retryWithdrawal(id) {
    if (!confirm('Re-approve withdrawal #' + id + ' for retry?')) return;
    $.get(Wo_Ajax_Requests_File(), {f: 'admin_setting', s: 'approve_withdrawal', withdrawal_id: id, hash_id: hash_id}, function(data) {
        if (data.status == 200) {
            $('#withdrawal-row-' + id).fadeOut(300, function() { $(this).remove(); });
        } else {
            alert(data.message || 'Error');
        }
    }, 'json');
}

function approveAll() {
    if (!confirm('Approve ALL pending withdrawals? This will queue them all for processing.')) return;
    $.get(Wo_Ajax_Requests_File(), {f: 'admin_setting', s: 'approve_all_withdrawals', hash_id: hash_id}, function(data) {
        if (data.status == 200) {
            location.reload();
        } else {
            alert(data.message || 'Error');
        }
    }, 'json');
}
</script>
