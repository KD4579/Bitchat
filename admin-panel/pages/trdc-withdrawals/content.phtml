// Count by status
$counts = array('pending' => 0, 'approved' => 0, 'processing' => 0, 'completed' => 0, 'failed' => 0, 'cancelled' => 0);
$countQ = mysqli_query($sqlConnect, "SELECT status, COUNT(*) as cnt FROM " . T_TRDC_WITHDRAWALS . " GROUP BY status");
if ($countQ) {
    while ($row = mysqli_fetch_assoc($countQ)) {
        $counts[$row['status']] = intval($row['cnt']);
    }
}
$totalAll = array_sum($counts);

// Fetch withdrawals
$statusFilter = '';
if ($filter_status !== 'all') {
    $safeStatus = Wo_Secure($filter_status);
    $statusFilter = " WHERE w.status = '{$safeStatus}'";
}

$totalQ = mysqli_query($sqlConnect, "SELECT COUNT(*) as cnt FROM " . T_TRDC_WITHDRAWALS . " w" . $statusFilter);
$totalRows = $totalQ ? intval(mysqli_fetch_assoc($totalQ)['cnt']) : 0;
$totalPages = max(1, ceil($totalRows / $per_page));

