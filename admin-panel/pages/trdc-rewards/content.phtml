<script>
$(document).ready(function() {
    $('#trdc-rewards-form').on('submit', function(e) {
        e.preventDefault();

        var form = $(this);
        var postData = {
            trdc_creator_rewards_enabled: form.find('[name=trdc_creator_rewards_enabled]').val()
        };

        // Collect reward config rows (if engine table exists)
        var keys = form.find('[name="rc_key[]"]');
        if (keys.length > 0) {
            var rewards = [];
            keys.each(function() {
                var key = $(this).val();
                rewards.push({
                    key: key,
                    enabled: form.find('[name=rc_enabled_' + key + ']').is(':checked') ? 1 : 0,
                    amount: parseFloat(form.find('[name=rc_amount_' + key + ']').val()) || 0,
                    max_per_day: parseInt(form.find('[name=rc_maxday_' + key + ']').val()) || 0,
                    cooldown_hours: parseInt(form.find('[name=rc_cooldown_' + key + ']').val()) || 0
                });
            });
            postData.reward_configs = JSON.stringify(rewards);
        } else {
            // Fallback: old milestone format
            postData.trdc_reward_milestones = JSON.stringify({
                post_likes_100: parseFloat(form.find('[name=m_post_likes_100]').val()) || 0,
                post_likes_500: parseFloat(form.find('[name=m_post_likes_500]').val()) || 0,
                post_likes_1000: parseFloat(form.find('[name=m_post_likes_1000]').val()) || 0,
                first_video_post: parseFloat(form.find('[name=m_first_video_post]').val()) || 0
            });
        }

        $.post(Wo_Ajax_Requests_File() + '?f=trdc_rewards', postData, function(data) {
            if (data.status == 200) {
                Wo_ShowNotifications('success', 'Reward settings saved successfully!');
            } else {
                Wo_ShowNotifications('error', data.message || 'Failed to save settings');
            }
        }, 'json').fail(function(xhr, status, error) {
            Wo_ShowNotifications('error', 'Request failed: ' + error);
        });
    });
});
</script>
