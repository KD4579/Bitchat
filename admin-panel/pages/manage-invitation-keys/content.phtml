<?php
// Invitation analytics
$_inv_total = 0;
$_inv_q = mysqli_query($sqlConnect, "SELECT COUNT(*) as total FROM " . T_INVITATIONS);
if ($_inv_q && $_inv_r = mysqli_fetch_assoc($_inv_q)) {
    $_inv_total = (int)$_inv_r['total'];
}

// Total referral links ever generated
$_inv_links = 0;
$_il_q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM `Wo_Invitation_Links`");
if ($_il_q && $_il_r = mysqli_fetch_assoc($_il_q)) { $_inv_links = (int)$_il_r['c']; }

// Total users who joined via referral
$_ref_total = 0;
$_rt_q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE referrer > 0 AND src != 'Fake'");
if ($_rt_q && $_rt_r = mysqli_fetch_assoc($_rt_q)) { $_ref_total = (int)$_rt_r['c']; }

// Top referrers — use first_name/last_name (Wo_Users has no 'name' column)
$_top_referrers = array();
$_ref_q = mysqli_query($sqlConnect, "SELECT u2.referrer AS ref_id, u1.username, CONCAT(u1.first_name, ' ', u1.last_name) AS name, COUNT(*) AS ref_count
    FROM " . T_USERS . " u2
    JOIN " . T_USERS . " u1 ON u2.referrer = u1.user_id
    WHERE u2.referrer > 0 AND u1.src != 'Fake'
    GROUP BY u2.referrer ORDER BY ref_count DESC LIMIT 10");
if ($_ref_q) {
    while ($_ref_r = mysqli_fetch_assoc($_ref_q)) { $_top_referrers[] = $_ref_r; }
}

// Recent referral joins (7d)
$_recent_joins = 0;
$_rj_q = mysqli_query($sqlConnect, "SELECT COUNT(*) as c FROM " . T_USERS . " WHERE referrer > 0 AND registered >= '" . date('Y-m-d', strtotime('-7 days')) . "' AND src != 'Fake'");
if ($_rj_q && $_rj_r = mysqli_fetch_assoc($_rj_q)) { $_recent_joins = (int)$_rj_r['c']; }
