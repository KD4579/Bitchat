<script>
$('#ghost-activity-form').on('submit', function(e) {
    e.preventDefault();
    var form = $(this);
    $.post(Wo_Ajax_Requests_File() + '?f=ghost_activity', {
        ghost_activity_enabled: form.find('[name=ghost_activity_enabled]').val(),
        ghost_activity_accounts: form.find('[name=ghost_activity_accounts]').val(),
        ghost_activity_min_delay: form.find('[name=ghost_activity_min_delay]').val(),
        ghost_activity_max_delay: form.find('[name=ghost_activity_max_delay]').val(),
        ghost_activity_max_per_hour: form.find('[name=ghost_activity_max_per_hour]').val(),
        ghost_activity_ratio_cap: form.find('[name=ghost_activity_ratio_cap]').val()
    }, function(data) {
        if (data.status == 200) {
            Wo_ShowNotifications('success', 'Settings saved successfully');
        } else {
            Wo_ShowNotifications('error', data.message || 'Failed to save');
        }
    }, 'json');
});
</script>
