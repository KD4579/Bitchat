<script>
$('#staking-settings-form').on('submit', function(e) {
    e.preventDefault();
    var $btn = $(this).find('button[type=submit]');
    $btn.prop('disabled', true).text('Saving...');

    $.post(Wo_Ajax_Requests_File() + '?f=staking_admin', $(this).serialize(), function(data) {
        if (data.status == 200) {
            $('#staking-save-result').html('<div class="alert alert-success">' + data.message + '</div>');
        } else {
            $('#staking-save-result').html('<div class="alert alert-danger">' + (data.message || 'Error saving settings') + '</div>');
        }
        $btn.prop('disabled', false).text('Save Staking Settings');
        setTimeout(function(){ $('#staking-save-result .alert').fadeOut(); }, 4000);
    }, 'json').fail(function() {
        $('#staking-save-result').html('<div class="alert alert-danger">Network error</div>');
        $btn.prop('disabled', false).text('Save Staking Settings');
    });
});

function resetDefaults() {
    if (!confirm('Reset all staking settings to defaults?')) return;
    var defaults = {
        staking_enabled: '1', staking_min_amount: '100', staking_max_amount: '0',
        staking_affiliate_percent: '10',
        staking_onchain_enabled: '1', staking_offchain_enabled: '1',
        staking_plan_1_days: '30', staking_plan_1_apy: '5', staking_plan_1_enabled: '1',
        staking_plan_2_days: '90', staking_plan_2_apy: '8', staking_plan_2_enabled: '1',
        staking_plan_3_days: '180', staking_plan_3_apy: '12', staking_plan_3_enabled: '1',
        staking_plan_4_days: '365', staking_plan_4_apy: '18', staking_plan_4_enabled: '1',
    };
    for (var key in defaults) {
        var el = $('[name="' + key + '"]');
        if (el.is('select')) el.val(defaults[key]);
        else el.val(defaults[key]);
    }
}
</script>
