<script>
function applyPreset(preset) {
    if (!confirm('Apply the "' + preset.replace('_', ' ') + '" preset? This will update multiple growth settings at once.')) return;

    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=growth_presets',
        type: 'POST',
        data: { preset: preset },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                Wo_ShowNotifications('success', 'Preset "' + preset.replace('_', ' ') + '" applied successfully');
                setTimeout(function() { window.location.reload(); }, 1000);
            } else {
                Wo_ShowNotifications('error', data.message || 'Failed to apply preset');
            }
        },
        error: function() {
            Wo_ShowNotifications('error', 'Request failed');
        }
    });
}
</script>
