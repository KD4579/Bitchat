<script>
function filterDeposits() {
    var status = document.getElementById('deposit-filter-status').value;
    var token = document.getElementById('deposit-filter-token').value;
    window.location.href = '?path=deposits&status=' + status + '&token=' + token;
}

function saveDepositSettings() {
    var form = document.getElementById('deposit-settings-form');
    var data = new FormData(form);
    data.append('type', 'save_deposit_settings');

    $.ajax({
        url: '<?php echo Wo_LoadAdminLinkSettings("admin_setting"); ?>',
        type: 'POST',
        data: data,
        processData: false,
        contentType: false,
        dataType: 'json',
        success: function(resp) {
            if (resp.status === 200) {
                swal('Success', 'Deposit settings saved', 'success');
            } else {
                swal('Error', resp.message || 'Failed to save settings', 'error');
            }
        },
        error: function() {
            swal('Error', 'Network error', 'error');
        }
    });
}

function manualCredit(depositId) {
    swal({
        title: 'Manual Credit',
        text: 'Are you sure you want to manually credit this deposit to the user?',
        type: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#10b981',
        confirmButtonText: 'Yes, credit it'
    }, function() {
        $.post('<?php echo Wo_LoadAdminLinkSettings("admin_setting"); ?>', {
            type: 'manual_credit_deposit',
            deposit_id: depositId
        }, function(resp) {
            if (resp.status === 200) {
                swal('Success', 'Deposit credited to user', 'success');
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                swal('Error', resp.message || 'Failed to credit', 'error');
            }
        }, 'json');
    });
}

function retrySweep(sweepId) {
    $.post('<?php echo Wo_LoadAdminLinkSettings("admin_setting"); ?>', {
        type: 'retry_sweep',
        sweep_id: sweepId
    }, function(resp) {
        if (resp.status === 200) {
            swal('Success', 'Sweep queued for retry', 'success');
            setTimeout(function() { location.reload(); }, 1500);
        } else {
            swal('Error', resp.message || 'Failed to retry', 'error');
        }
    }, 'json');
}
</script>
