<?php if (!Wo_IsAdmin()) { header("Location: " . Wo_LoadAdminLinkSettings('dashboard')); exit(); } ?>
<div class="col-md-12">
    <div class="panel panel-default">
        <div class="panel-heading">
            <h3 class="panel-title">Creator Mode</h3>
            <p class="text-muted">Enable/disable the creator system. Creators get a badge on posts, access to analytics, and TRDC milestone rewards.</p>
        </div>
        <div class="panel-body">
            <form onsubmit="return bcSaveCreatorSettings(this);" class="form-inline" style="margin-bottom:20px;">
                <div class="form-group" style="margin-right:15px;">
                    <label>Creator Mode</label>
                    <select name="creator_mode_enabled" id="bc-creator-mode-select" class="form-control" style="margin-left:10px;">
                        <option value="0" <?php echo (($wo['config']['creator_mode_enabled'] ?? '0') == '0') ? 'selected' : ''; ?>>Disabled</option>
                        <option value="1" <?php echo (($wo['config']['creator_mode_enabled'] ?? '0') == '1') ? 'selected' : ''; ?>>Enabled</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </form>

            <hr>
            <h4>Manage Creators</h4>
            <p class="text-muted">Add or remove creator status for users by entering their User ID.</p>

            <div class="row" style="margin-bottom:20px;">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" id="creator-user-id" class="form-control" placeholder="User ID" autocomplete="off">
                        <span class="input-group-btn">
                            <button class="btn btn-success" type="button" onclick="bcGrantCreator();">Grant Creator</button>
                            <button class="btn btn-danger" type="button" onclick="bcRemoveCreatorById();">Remove Creator</button>
                        </span>
                    </div>
                </div>
            </div>

            <h4>Current Creators</h4>
            <?php
            $creators = array();
            $cQuery = mysqli_query($sqlConnect, "SELECT user_id FROM Wo_Users WHERE is_creator = 1 ORDER BY user_id ASC LIMIT 100");
            if ($cQuery) {
                while ($row = mysqli_fetch_assoc($cQuery)) {
                    $creators[] = $row['user_id'];
                }
            }
            ?>

            <?php if (empty($creators)): ?>
                <p class="text-muted">No creators yet.</p>
            <?php else: ?>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>User ID</th>
                                <th>Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        <?php foreach ($creators as $cid): ?>
                            <?php $cUser = Wo_UserData($cid); ?>
                            <tr id="creator-row-<?php echo $cid; ?>">
                                <td><?php echo $cid; ?></td>
                                <td>
                                    <?php if (!empty($cUser['name'])): ?>
                                        <a href="<?php echo $cUser['url']; ?>" target="_blank"><?php echo htmlspecialchars($cUser['name']); ?></a>
                                    <?php else: ?>
                                        User #<?php echo $cid; ?>
                                    <?php endif; ?>
                                </td>
                                <td>
                                    <button class="btn btn-xs btn-danger" type="button" onclick="bcRemoveCreator(<?php echo $cid; ?>);">Remove</button>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>

<script>
function bcSaveCreatorSettings(form) {
    var val = document.getElementById('bc-creator-mode-select').value;
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'save_settings', creator_mode_enabled: val },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                alert('Settings saved successfully');
            } else {
                alert(data.message || 'Failed to save');
            }
        },
        error: function() { alert('Request failed'); }
    });
    return false;
}

function bcGrantCreator() {
    var uid = document.getElementById('creator-user-id').value;
    if (!uid || uid == '0') { alert('Please enter a User ID'); return; }
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'admin_toggle', user_id: uid, enable: '1' },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                alert('Creator status granted to user #' + uid);
                window.location.reload();
            } else {
                alert(data.message || 'Failed to grant creator status');
            }
        },
        error: function() { alert('Request failed'); }
    });
}

function bcRemoveCreatorById() {
    var uid = document.getElementById('creator-user-id').value;
    if (!uid || uid == '0') { alert('Please enter a User ID'); return; }
    bcRemoveCreator(uid);
}

function bcRemoveCreator(uid) {
    if (!confirm('Remove creator status from user #' + uid + '?')) return;
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'admin_toggle', user_id: uid, enable: '0' },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                var row = document.getElementById('creator-row-' + uid);
                if (row) row.style.display = 'none';
                alert('Creator status removed from user #' + uid);
            } else {
                alert(data.message || 'Failed to remove creator status');
            }
        },
        error: function() { alert('Request failed'); }
    });
}
</script>
