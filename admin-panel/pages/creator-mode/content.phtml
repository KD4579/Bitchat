<script>
function bcamToast(msg, type) {
    var t = document.getElementById('bcam-toast');
    t.textContent = msg;
    t.className = 'bcam-toast bcam-toast-' + (type || 'success') + ' show';
    clearTimeout(t._timer);
    t._timer = setTimeout(function() { t.className = 'bcam-toast'; }, 3000);
}

function bcamToggleSystem(cb) {
    var val = cb.checked ? '1' : '0';
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'save_settings', creator_mode_enabled: val },
        dataType: 'json',
        success: function(data) {
            var badge = document.getElementById('bcam-status-badge');
            if (data.status == 200) {
                badge.className = 'bcam-status ' + (cb.checked ? 'bcam-status-on' : 'bcam-status-off');
                badge.textContent = cb.checked ? 'Active' : 'Inactive';
                bcamToast('Creator mode ' + (cb.checked ? 'enabled' : 'disabled'));
            } else {
                cb.checked = !cb.checked;
                bcamToast(data.message || 'Failed to save', 'error');
            }
        },
        error: function() { cb.checked = !cb.checked; bcamToast('Request failed', 'error'); }
    });
}

function bcamGrant() {
    var uid = document.getElementById('bcam-user-id').value.trim();
    if (!uid || uid == '0') { bcamToast('Please enter a User ID', 'error'); return; }
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'admin_toggle', user_id: uid, enable: '1' },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                bcamToast('Creator status granted to user #' + uid);
                document.getElementById('bcam-user-id').value = '';
                setTimeout(function() { window.location.reload(); }, 800);
            } else {
                bcamToast(data.message || 'Failed to grant creator status', 'error');
            }
        },
        error: function() { bcamToast('Request failed', 'error'); }
    });
}

function bcamFreezeTRDC(uid, name) {
    if (!confirm('Freeze TRDC earning for ' + (name || 'user #' + uid) + '? They will not earn TRDC from milestones until unfrozen.')) return;
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'freeze_trdc', user_id: uid },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                bcamToast('TRDC earning frozen for ' + (name || 'user #' + uid));
            } else {
                bcamToast(data.message || 'Failed to freeze', 'error');
            }
        },
        error: function() { bcamToast('Request failed', 'error'); }
    });
}

function bcamRemove(uid, name) {
    if (!confirm('Remove creator status from ' + (name || 'user #' + uid) + '?')) return;
    $.ajax({
        url: Wo_Ajax_Requests_File() + '?f=creator',
        type: 'POST',
        data: { action: 'admin_toggle', user_id: uid, enable: '0' },
        dataType: 'json',
        success: function(data) {
            if (data.status == 200) {
                var row = document.getElementById('bcam-row-' + uid);
                if (row) {
                    row.style.transition = 'opacity 0.3s';
                    row.style.opacity = '0';
                    setTimeout(function() { row.remove(); }, 300);
                }
                bcamToast('Creator status removed from ' + (name || 'user #' + uid));
            } else {
                bcamToast(data.message || 'Failed to remove', 'error');
            }
        },
        error: function() { bcamToast('Request failed', 'error'); }
    });
}
</script>
