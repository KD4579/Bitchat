<script>
function controlBot(bot, action) {
    var btn = (bot === 'grid') ?
        (action === 'start' ? '#btn-grid-start' : '#btn-grid-stop') :
        (action === 'start' ? '#btn-arb-start' : '#btn-arb-stop');
    $(btn).prop('disabled', true).text(action === 'start' ? 'Starting...' : 'Stopping...');

    $.post(Wo_Ajax_Requests_File() + '?f=trading_bot', {
        bot_control: bot,
        bot_action: action
    }, function(data) {
        if (data.status === 200) {
            var isGridOn = data.grid_running;
            var isArbOn = data.arb_running;

            // Update status badges
            $('#grid-status-badge').text(isGridOn ? 'RUNNING' : 'STOPPED')
                .removeClass('label-success label-danger').addClass(isGridOn ? 'label-success' : 'label-danger');
            $('#arb-status-badge').text(isArbOn ? 'RUNNING' : 'STOPPED')
                .removeClass('label-success label-danger').addClass(isArbOn ? 'label-success' : 'label-danger');

            // Update start/stop buttons
            $('#btn-grid-start').prop('disabled', isGridOn).html('<i class="material-icons" style="font-size:14px;vertical-align:middle;">play_arrow</i> Start');
            $('#btn-grid-stop').prop('disabled', !isGridOn).html('<i class="material-icons" style="font-size:14px;vertical-align:middle;">stop</i> Stop');
            $('#btn-arb-start').prop('disabled', isArbOn).html('<i class="material-icons" style="font-size:14px;vertical-align:middle;">play_arrow</i> Start');
            $('#btn-arb-stop').prop('disabled', !isArbOn).html('<i class="material-icons" style="font-size:14px;vertical-align:middle;">stop</i> Stop');

            // Auto-update Bot Status and Trading Mode dropdowns
            if (data.bot_mode) {
                $('#bot_mode_select').val(data.bot_mode);
            }
            $('[name="bot_enabled"]').val(data.bot_enabled);

            // Update border colors
            $('#btn-grid-start').closest('.panel').css('border-left-color', isGridOn ? '#4CAF50' : '#f44336');
            $('#btn-arb-start').closest('.panel').css('border-left-color', isArbOn ? '#4CAF50' : '#f44336');
        } else {
            alert(data.message || 'Failed');
            $(btn).prop('disabled', false).html(action === 'start' ?
                '<i class="material-icons" style="font-size:14px;vertical-align:middle;">play_arrow</i> Start' :
                '<i class="material-icons" style="font-size:14px;vertical-align:middle;">stop</i> Stop');
        }
    }, 'json').fail(function() {
        alert('Request failed');
        $(btn).prop('disabled', false);
    });
}

$(document).ready(function() {
    $('#trading-bot-form').on('submit', function(e) {
        e.preventDefault();
        var form = $(this);
        var postData = {};

        // Collect all form fields
        form.find('input, select').each(function() {
            var name = $(this).attr('name');
            if (name) {
                postData[name] = $(this).val();
            }
        });

        $.post(Wo_Ajax_Requests_File() + '?f=trading_bot', postData, function(data) {
            if (data.status == 200) {
                alert('Bot configuration saved successfully!');
            } else {
                alert(data.message || 'Failed to save configuration');
            }
        }, 'json').fail(function(xhr, status, error) {
            alert('Request failed: ' + error);
        });
    });

    $('#reset-defaults').on('click', function() {
        if (!confirm('Reset all bot parameters to recommended defaults and save immediately? This cannot be undone.')) return;

        var defaults = {
            bot_enabled: '0',
            bot_mode: 'both',
            bot_rpc_url: 'https://bsc-dataseed1.binance.org',
            bot_spread_percent: '3',
            bot_grid_levels: '4',
            bot_grid_spacing: '2',
            bot_order_size_trdc: '2000',
            bot_order_size_min: '1500',
            bot_order_size_max: '2500',
            bot_max_consecutive: '3',
            bot_max_slippage: '3',
            bot_daily_loss_limit: '5',
            bot_cooldown_seconds: '3600',
            bot_max_trade_percent: '3',
            bot_min_tvl: '100',
            bot_min_arb_profit: '0.3',
            bot_arb_max_size: '5000',
            bot_max_gas_gwei: '10',
            bot_lp_exit_alert: '30',
            bot_tvl_drop_alert: '15',
            bot_pool_trdc_usdt: '0x7b57fa13cca5093f5d724823d58503dfd02ff07c',
            bot_pool_trdc_wbnb: '0x0b5e165fcb524fbb2d313f3d573d79372913788b',
            bot_pool_usdt_fee: '100',
            bot_pool_wbnb_fee: '2500'
        };

        // Fill form fields
        $.each(defaults, function(key, val) {
            $('[name="' + key + '"]').val(val);
        });

        // Save to DB immediately
        $.post(Wo_Ajax_Requests_File() + '?f=trading_bot', defaults, function(data) {
            if (data.status === 200) {
                alert('Defaults restored and saved successfully.');
            } else {
                alert(data.message || 'Failed to save defaults.');
            }
        }, 'json').fail(function(xhr, status, error) {
            alert('Request failed: ' + error);
        });
    });
});
</script>
