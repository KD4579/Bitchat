function resetBotForm() {
    $('#bc-bot-form-title').text('Create New Bot');
    $('#bc-bot-edit-id').val('').data('content-type', 'rss');
    $('#bc-bot-name').val('');
    $('#bc-bot-username').val('').prop('disabled', false);
    $('#bc-bot-category').val('world_news');
    $('#bc-bot-frequency').val(30);
    $('#bc-bot-max-posts').val(20);
    $('#bc-bot-thumbnail').val('1');
    $('#bc-bot-sources').val('').attr('placeholder', "https://feeds.bbci.co.uk/news/world/rss.xml\nhttps://rss.nytimes.com/services/xml/rss/nyt/World.xml\nhttps://feeds.reuters.com/reuters/worldNews");
}

function editBot(id) {
    var bot = bcBotData.find(function(b) { return b.id == id; });
    if (!bot) return;
    $('#bc-bot-form-title').text('Edit Bot: ' + bot.name);
    $('#bc-bot-edit-id').val(bot.id);
    $('#bc-bot-edit-id').data('content-type', bot.content_type || 'rss');
    $('#bc-bot-name').val(bot.name);
    $('#bc-bot-username').val(bot.username).prop('disabled', true);
    $('#bc-bot-category').val(bot.category);
    $('#bc-bot-frequency').val(bot.post_frequency);
    $('#bc-bot-max-posts').val(bot.max_posts_per_day);
    $('#bc-bot-thumbnail').val(bot.include_thumbnail);
    $('#bc-bot-sources').val(bot.news_sources || '');
    // Show note for template bots
    if (bot.content_type === 'template') {
        $('#bc-bot-sources').attr('placeholder', 'Optional for template bots. Add RSS URLs to switch to RSS mode.');
    } else {
        $('#bc-bot-sources').attr('placeholder', "https://feeds.bbci.co.uk/news/world/rss.xml\nhttps://rss.nytimes.com/services/xml/rss/nyt/World.xml\nhttps://feeds.reuters.com/reuters/worldNews");
    }
    $('#bc-bot-form-card').slideDown(300);
    $('html,body').animate({scrollTop: $('#bc-bot-form-card').offset().top - 80}, 300);
}

function saveBotAccount() {
    var data = {
        hash_id: '<?php echo Wo_CreateSession(); ?>',
        bot_id: $('#bc-bot-edit-id').val(),
        name: $('#bc-bot-name').val().trim(),
        username: $('#bc-bot-username').val().trim(),
        category: $('#bc-bot-category').val(),
        post_frequency: $('#bc-bot-frequency').val(),
        max_posts_per_day: $('#bc-bot-max-posts').val(),
        include_thumbnail: $('#bc-bot-thumbnail').val(),
        news_sources: $('#bc-bot-sources').val().trim()
    };
    if (!data.name || !data.username) {
        alert('Name and username are required.');
        return;
    }
    var isTemplate = $('#bc-bot-edit-id').data('content-type') === 'template';
    if (!data.news_sources && !isTemplate) {
        alert('Please add at least one RSS feed URL.');
        return;
    }
    $('#bc-bot-save-btn').prop('disabled', true).text('Saving...');
    $.post(Wo_Ajax_Requests_File() + '?f=admin_setting&s=save_news_bot', data, function(resp) {
        $('#bc-bot-save-btn').prop('disabled', false).text('Save Bot');
        if (resp.status == 200) {
            location.reload();
        } else {
            alert(resp.message || 'Error saving bot.');
        }
    }).fail(function() {
        $('#bc-bot-save-btn').prop('disabled', false).text('Save Bot');
        alert('Network error.');
    });
}

function toggleBot(id, enable) {
    $.post(Wo_Ajax_Requests_File() + '?f=admin_setting&s=toggle_news_bot', {
        hash_id: '<?php echo Wo_CreateSession(); ?>',
        bot_id: id,
        enabled: enable
    }, function(resp) {
        if (resp.status == 200) location.reload();
        else alert(resp.message || 'Error');
    });
}

function deleteBot(id) {
    if (!confirm('Delete this bot and its user account? This cannot be undone.')) return;
    $.post(Wo_Ajax_Requests_File() + '?f=admin_setting&s=delete_news_bot', {
        hash_id: '<?php echo Wo_CreateSession(); ?>',
        bot_id: id
    }, function(resp) {
        if (resp.status == 200) {
            $('#bc-bot-' + id).fadeOut(300, function() { $(this).remove(); });
        } else {
            alert(resp.message || 'Error');
        }
    });
}

function runBotNow(id) {
    var btn = event.target.closest('button');
    $(btn).prop('disabled', true);
    $.post(Wo_Ajax_Requests_File() + '?f=admin_setting&s=run_news_bot_now', {
        hash_id: '<?php echo Wo_CreateSession(); ?>',
        bot_id: id
    }, function(resp) {
        $(btn).prop('disabled', false);
        if (resp.status == 200) {
            alert('Posted ' + resp.count + ' new article(s).');
            if (resp.count > 0) location.reload();
        } else {
            alert(resp.message || 'Error running bot.');
        }
    }).fail(function() {
        $(btn).prop('disabled', false);
        alert('Network error.');
    });
}
</script>
