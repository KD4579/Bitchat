# BSC RPC endpoint
RPC_URL=https://bsc-dataseed1.binance.org

# Hot wallet private key (same as withdrawal processor)
HOT_WALLET_KEY=0x_YOUR_PRIVATE_KEY_HERE

# HD wallet seed phrase (BIP-39 mnemonic) for generating deposit addresses
HD_SEED_PHRASE=your twelve word seed phrase goes here replace with actual words

# Database (optional — falls back to ../config.json)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=bitchat
