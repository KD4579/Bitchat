# Platform wallet private key (BSC) — holds TRDC tokens + BNB for gas
# IMPORTANT: Use a dedicated withdrawal wallet, NOT the trading bot wallet
BOT_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# BSC RPC (optional — defaults to bsc-dataseed1.binance.org)
RPC_URL=https://bsc-dataseed1.binance.org

# Database (optional — falls back to nodejs/config.json)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=bitchat
